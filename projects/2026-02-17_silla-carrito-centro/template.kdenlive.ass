Dialogue: 0,00:00:00.00,00:00:01.63,Default,,0,0,0,,Plaza del Colegio \Ndel Patriarca.
Dialogue: 0,00:00:01.63,00:00:03.67,Default,,0,0,0,,Pleno centro \Nde Valencia.
Dialogue: 0,00:00:03.67,00:00:05.57,Default,,0,0,0,,Y ahi, \Nen una esquina...
Dialogue: 0,00:00:05.57,00:00:06.97,Default,,0,0,0,,esto no me \Nlo esperaba.
Dialogue: 0,00:00:06.97,00:00:07.80,Default,,0,0,0,,No os vayais.
Dialogue: 0,00:00:07.80,00:00:08.57,Default,,0,0,0,,Hay mas.
Dialogue: 0,00:00:08.57,00:00:09.40,Default,,0,0,0,,Es que...
Dialogue: 0,00:00:09.40,00:00:09.97,Default,,0,0,0,,alguien por aqui
Dialogue: 0,00:00:09.97,00:00:11.77,Default,,0,0,0,,necesita justo \Nlo que acabo de ver.
Dialogue: 0,00:00:11.77,00:00:12.27,Default,,0,0,0,,Seguro.
Dialogue: 0,00:00:12.27,00:00:13.37,Default,,0,0,0,,Pasa por esta plaza
Dialogue: 0,00:00:13.37,00:00:14.67,Default,,0,0,0,,cada manana \Ncamino al trabajo.
Dialogue: 0,00:00:14.67,00:00:16.47,Default,,0,0,0,,Y no se va \Na enterar nunca.
Dialogue: 0,00:00:16.47,00:00:18.23,Default,,0,0,0,,Porque no hay \Nmanera de saberlo.
Dialogue: 0,00:00:18.23,00:00:19.93,Default,,0,0,0,,Dos personas \Nque se necesitan
Dialogue: 0,00:00:19.93,00:00:21.20,Default,,0,0,0,,y que no se van \Na cruzar.
Dialogue: 0,00:00:21.20,00:00:22.83,Default,,0,0,0,,O no se iban \Na cruzar.
Dialogue: 0,00:00:22.83,00:00:23.87,Default,,0,0,0,,Saco el movil.
Dialogue: 0,00:00:23.87,00:00:24.57,Default,,0,0,0,,Givore.
Dialogue: 0,00:00:24.57,00:00:26.37,Default,,0,0,0,,Foto, \Ndos palabras, \Npublico.
Dialogue: 0,00:00:26.37,00:00:27.40,Default,,0,0,0,,Medio minuto.
Dialogue: 0,00:00:27.40,00:00:28.47,Default,,0,0,0,,Y ahora mirad \Nlo que habia.
Dialogue: 0,00:00:28.47,00:00:29.37,Default,,0,0,0,,Una silla de oficina
Dialogue: 0,00:00:29.37,00:00:29.83,Default,,0,0,0,,en buen estado.
Dialogue: 0,00:00:29.83,00:00:32.40,Default,,0,0,0,,Con ruedas, \Nregulable,
Dialogue: 0,00:00:32.40,00:00:33.57,Default,,0,0,0,,de esas que \Nen tienda
Dialogue: 0,00:00:33.57,00:00:34.57,Default,,0,0,0,,cuestan lo suyo.
Dialogue: 0,00:00:34.57,00:00:35.60,Default,,0,0,0,,Y al lado...
Dialogue: 0,00:00:35.60,00:00:36.60,Default,,0,0,0,,un carrito de compras
Dialogue: 0,00:00:36.60,00:00:37.63,Default,,0,0,0,,que va perfecto.
Dialogue: 0,00:00:37.63,00:00:39.03,Default,,0,0,0,,Los dos, ahi, \Njunto a la plaza.
Dialogue: 0,00:00:39.03,00:00:41.37,Default,,0,0,0,,Todo el centro \Nlos puede ver ahora.
Dialogue: 0,00:00:41.37,00:00:42.57,Default,,0,0,0,,Alguien va a abrir \Nla app
Dialogue: 0,00:00:42.57,00:00:43.60,Default,,0,0,0,,y va a pensar...
Dialogue: 0,00:00:43.60,00:00:45.17,Default,,0,0,0,,justo lo que \Nnecesitaba.
Dialogue: 0,00:00:45.17,00:00:46.60,Default,,0,0,0,,El sol cae \Nsobre la plaza.
Dialogue: 0,00:00:46.60,00:00:48.53,Default,,0,0,0,,Otro paseo, \Notro hallazgo.
Dialogue: 0,00:00:48.53,00:00:49.07,Default,,0,0,0,,Si quereis ver
Dialogue: 0,00:00:49.07,00:00:50.63,Default,,0,0,0,,que sale la \Nproxima semana...
Dialogue: 0,00:00:50.63,00:00:51.40,Default,,0,0,0,,seguidme.
Dialogue: 0,00:00:51.40,00:00:52.17,Default,,0,0,0,,Nos vemos.
