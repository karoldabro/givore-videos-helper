      "clips": [
        {
          "clip_id": "sub0",
          "text": "Esto estaba\nen la calle",
          "position": 0.0,
          "in": 0.0,
          "out": 1.08,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "hace diez minutos.\nPerfectamente bien.",
          "position": 1.08,
          "in": 0.0,
          "out": 2.64,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Tu vecino\nde dos calles",
          "position": 3.72,
          "in": 0.0,
          "out": 1.0399999999999996,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "mas alla\npuede que necesite",
          "position": 4.76,
          "in": 0.0,
          "out": 1.5200000000000005,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "justo esto.\nY no lo sabe.",
          "position": 6.28,
          "in": 0.0,
          "out": 1.7999999999999998,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "Cosas utiles,\nesperando",
          "position": 8.08,
          "in": 0.0,
          "out": 1.2799999999999994,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "a que alguien\nlas vea.",
          "position": 9.36,
          "in": 0.0,
          "out": 1.08,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Pero eso\ntiene solucion.",
          "position": 10.44,
          "in": 0.0,
          "out": 1.08,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Y es muy facil.",
          "position": 11.52,
          "in": 0.0,
          "out": 1.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Reutilizar,\nrenovar,",
          "position": 12.64,
          "in": 0.0,
          "out": 1.5999999999999996,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "compartir\ncon quien lo necesita.",
          "position": 14.24,
          "in": 0.0,
          "out": 1.8800000000000008,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Darle otra vida\nen vez de tirarlo.",
          "position": 16.12,
          "in": 0.0,
          "out": 2.0799999999999983,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "Solo falta\nla conexion.",
          "position": 18.2,
          "in": 0.0,
          "out": 1.2800000000000011,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "Guardad esto\npara cuando veais",
          "position": 19.48,
          "in": 0.0,
          "out": 1.6400000000000006,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "algo en la calle.",
