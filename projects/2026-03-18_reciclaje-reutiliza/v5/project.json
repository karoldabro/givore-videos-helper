      "clips": [
        {
          "clip_id": "sub0",
          "text": "Esto es para todos\nlos que odiais",
          "position": 0.0,
          "in": 0.0,
          "out": 1.64,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "el desperdicio.\nQuedaos.",
          "position": 1.64,
          "in": 0.0,
          "out": 1.76,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Esto no va\na durar aqui.",
          "position": 3.4,
          "in": 0.0,
          "out": 1.4,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Ma\u00f1ana puede\nque ya no este.",
          "position": 4.8,
          "in": 0.0,
          "out": 1.3600000000000003,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "Cosas que funcionan,\ncon fecha",
          "position": 6.16,
          "in": 0.0,
          "out": 1.4799999999999995,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "de caducidad\nen la acera.",
          "position": 7.64,
          "in": 0.0,
          "out": 1.4799999999999995,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Pero hay una forma\nde arreglarlo.",
          "position": 9.12,
          "in": 0.0,
          "out": 2.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Y es mas simple\nde lo que pensais.",
          "position": 11.24,
          "in": 0.0,
          "out": 1.879999999999999,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Compartir\nantes de tirar.",
          "position": 13.12,
          "in": 0.0,
          "out": 1.8800000000000008,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Renovar antes\nde desechar.",
          "position": 15.0,
          "in": 0.0,
          "out": 1.6400000000000006,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "Reutilizar lo que\ntodavia vale.",
          "position": 16.64,
          "in": 0.0,
          "out": 1.879999999999999,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Solo falta\nque lo hagamos.",
          "position": 18.52,
          "in": 0.0,
          "out": 1.3200000000000003,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "Seguidme si os gusta\ndar segunda vida",
          "position": 19.84,
          "in": 0.0,
          "out": 2.0,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "a las cosas.",
          "position": 21.84,
          "in": 0.0,
          "out": 0.879999999999999,
          "filters": []
        }
