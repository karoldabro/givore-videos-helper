          "in": 0.0,
          "out": 1.12,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Esto es\npara vosotros.",
          "position": 4.24,
          "in": 0.0,
          "out": 1.12,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "Cada dia se pierden\nobjetos que funcionan.",
          "position": 5.36,
          "in": 0.0,
          "out": 2.4399999999999995,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "Muebles,\ncosas utiles...",
          "position": 7.8,
          "in": 0.0,
          "out": 1.2000000000000002,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "porque no hay\nforma facil",
          "position": 9.0,
          "in": 0.0,
          "out": 1.5600000000000005,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "de conectar\na quien lo tiene",
          "position": 10.56,
          "in": 0.0,
          "out": 1.1199999999999992,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "con quien lo quiere.",
          "position": 11.68,
