        {
          "clip_id": "sub0",
          "text": "Otro dia...\notra vuelta",
          "position": 0.0,
          "in": 0.0,
          "out": 1.24,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "por la ciudad.",
          "position": 1.24,
          "in": 0.0,
          "out": 0.6000000000000001,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "A ver que\nencontramos.",
          "position": 1.84,
          "in": 0.0,
          "out": 0.9999999999999998,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Hay gente\na quinientos metros",
          "position": 2.84,
          "in": 0.0,
          "out": 2.0,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "de aqui\nque le vendria",
          "position": 4.84,
          "in": 0.0,
          "out": 0.7199999999999998,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "genial esto.",
          "position": 5.56,
          "in": 0.0,
          "out": 1.08,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Y no tienen\nni idea",
          "position": 6.64,
          "in": 0.0,
          "out": 0.9199999999999999,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "de que existe.",
          "position": 7.56,
          "in": 0.0,
          "out": 0.6800000000000006,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Objetos utiles,\ninvisibles.",
          "position": 8.24,
          "in": 0.0,
          "out": 2.1999999999999993,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Os ense\u00f1o.",
          "position": 10.44,
          "in": 0.0,
          "out": 0.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "Antes de\ndesechar algo,",
          "position": 11.28,
          "in": 0.0,
          "out": 1.5600000000000005,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "pensad.\nRenovar,",
          "position": 12.84,
          "in": 0.0,
          "out": 1.6799999999999997,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "reutilizar,\ncompartir.",
          "position": 14.52,
          "in": 0.0,
          "out": 2.039999999999999,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "Lo que para ti sobra,\npara otro",
          "position": 16.56,
          "in": 0.0,
          "out": 1.5600000000000023,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "es justo\nlo que busca.",
          "position": 18.12,
          "in": 0.0,
          "out": 0.9599999999999973,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "Compartidlo\ncon vuestros vecinos.",
