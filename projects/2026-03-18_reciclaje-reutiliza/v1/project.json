      "clips": [
        {
          "clip_id": "sub0",
          "text": "Pedaleando por\nla ciudad...",
          "position": 0.0,
          "in": 0.0,
          "out": 1.4,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "y otra vez\nlo mismo.",
          "position": 1.4,
          "in": 0.0,
          "out": 1.08,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Cosas perfectas,\nahi tiradas.",
          "position": 2.48,
          "in": 0.0,
          "out": 2.0000000000000004,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Es que cada dia\nse pierden muebles,",
          "position": 4.48,
          "in": 0.0,
          "out": 1.88,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "objetos,\ncosas que funcionan...",
          "position": 6.36,
          "in": 0.0,
          "out": 1.88,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "porque no hay\nmanera facil",
          "position": 8.24,
          "in": 0.0,
          "out": 1.2400000000000002,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "de conectar\na quien lo tiene",
          "position": 9.48,
          "in": 0.0,
          "out": 1.1999999999999993,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "con quien\nlo necesita.",
          "position": 10.68,
          "in": 0.0,
          "out": 0.9199999999999999,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Pero eso\npuede cambiar.",
          "position": 11.6,
          "in": 0.0,
          "out": 1.8800000000000008,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Y es mas simple\nde lo que pensais.",
          "position": 13.48,
          "in": 0.0,
          "out": 2.08,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "Antes de\ntirar algo...",
          "position": 15.56,
          "in": 0.0,
          "out": 0.9199999999999999,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "pensad.\nReutilizar,",
          "position": 16.48,
          "in": 0.0,
          "out": 1.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "renovar,\ncompartir.",
          "position": 18.44,
          "in": 0.0,
          "out": 1.1999999999999993,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "Darle otra vida\nes mas facil",
          "position": 19.64,
          "in": 0.0,
          "out": 1.879999999999999,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "que tirarlo.",
          "position": 21.52,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "Y alguien cerca\nseguro que",
          "position": 22.52,
          "in": 0.0,
          "out": 1.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "lo aprovecharia.",
          "position": 23.64,
          "in": 0.0,
          "out": 1.1600000000000001,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "Pequenos gestos,\ngrandes cambios.",
          "position": 24.8,
          "in": 0.0,
          "out": 1.879999999999999,
          "filters": []
        },
        {
          "clip_id": "sub18",
          "text": "Seguidme\npara mas.",
          "position": 26.68,
          "in": 0.0,
          "out": 1.0399999999999991,
          "filters": []
        }
