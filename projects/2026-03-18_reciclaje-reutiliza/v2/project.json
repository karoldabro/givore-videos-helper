        {
          "clip_id": "sub0",
          "text": "Es que...\nmirad.",
          "position": 0.0,
          "in": 0.0,
          "out": 1.44,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "Mirad esto.",
          "position": 1.44,
          "in": 0.0,
          "out": 0.9199999999999999,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Cosas perfectas,\nesperando en la calle.",
          "position": 2.36,
          "in": 0.0,
          "out": 2.28,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Ma\u00f1ana ya\nno estaran.",
          "position": 4.64,
          "in": 0.0,
          "out": 1.2800000000000002,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "O en un contenedor,\no rotas.",
          "position": 5.92,
          "in": 0.0,
          "out": 2.0,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "Objetos que funcionan...\ncon las horas contadas.",
          "position": 7.92,
          "in": 0.0,
          "out": 2.84,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Mirad lo que\nse puede hacer.",
          "position": 10.76,
          "in": 0.0,
          "out": 1.5199999999999996,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Reutilizar,\nrenovar,",
          "position": 12.28,
          "in": 0.0,
          "out": 1.4000000000000004,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "darle otra\noportunidad.",
          "position": 13.68,
          "in": 0.0,
          "out": 1.2800000000000011,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Antes de tirar,\npensad",
          "position": 14.96,
          "in": 0.0,
          "out": 1.6799999999999997,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "si alguien mas\nlo quiere.",
          "position": 16.64,
          "in": 0.0,
          "out": 1.1999999999999993,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Porque seguro\nque si.",
          "position": 17.84,
          "in": 0.0,
          "out": 1.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub12",
