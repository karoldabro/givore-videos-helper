      "clips": [
        {
          "clip_id": "sub0",
          "text": "Cada dia,\ncientos de cosas",
          "position": 0.0,
          "in": 0.0,
          "out": 1.52,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "utiles acaban\ndonde no deberian.",
          "position": 1.52,
          "in": 0.0,
          "out": 2.16,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Cientos.",
          "position": 3.68,
          "in": 0.0,
          "out": 0.9199999999999995,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Se pierden muebles,\nelectrodomesticos,",
          "position": 4.6,
          "in": 0.0,
          "out": 1.8800000000000008,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "objetos que funcionan...",
          "position": 6.48,
          "in": 0.0,
          "out": 1.3999999999999995,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "porque falta\nuna conexion.",
          "position": 7.88,
          "in": 0.0,
          "out": 1.5599999999999996,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Alguien lo deja,\nalguien lo necesita,",
          "position": 9.44,
          "in": 0.0,
          "out": 1.6400000000000006,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "pero no\nse encuentran.",
          "position": 11.08,
          "in": 0.0,
          "out": 1.4399999999999995,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Va, que os\nlo cuento.",
          "position": 12.52,
          "in": 0.0,
          "out": 1.3200000000000003,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Renovar,\nreutilizar,",
          "position": 13.84,
          "in": 0.0,
          "out": 1.2400000000000002,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "compartir.",
          "position": 15.08,
          "in": 0.0,
          "out": 0.9599999999999991,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Es mas facil\nque tirarlo.",
          "position": 16.04,
          "in": 0.0,
          "out": 1.4000000000000021,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "Y alguien cerca\nlo aprovecharia",
          "position": 17.44,
          "in": 0.0,
          "out": 1.2799999999999976,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "encantado.",
          "position": 18.72,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Antes de tirar,\npensad",
          "position": 19.72,
          "in": 0.0,
          "out": 1.3200000000000003,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "si alguien mas\nlo puede querer.",
          "position": 21.04,
          "in": 0.0,
          "out": 2.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "Nos vemos\nen el proximo paseo.",
