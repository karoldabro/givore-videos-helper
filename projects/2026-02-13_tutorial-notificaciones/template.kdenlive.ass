Dialogue: 0,00:00:00.00,00:00:00.93,Default,,0,0,0,,Si usáis Givore
Dialogue: 0,00:00:00.93,00:00:03.07,Default,,0,0,0,,y no habéis tocado \Nlas notificaciones...
Dialogue: 0,00:00:03.07,00:00:04.40,Default,,0,0,0,,os estáis perdiendo \Ncosas.
Dialogue: 0,00:00:04.40,00:00:05.27,Default,,0,0,0,,La app os avisa
Dialogue: 0,00:00:05.27,00:00:06.53,Default,,0,0,0,,cuando aparece \Nalgo nuevo
Dialogue: 0,00:00:06.53,00:00:07.20,Default,,0,0,0,,en vuestra zona.
Dialogue: 0,00:00:07.20,00:00:08.57,Default,,0,0,0,,Cuando algo \Nque buscáis
Dialogue: 0,00:00:08.57,00:00:09.60,Default,,0,0,0,,se publica cerca.
Dialogue: 0,00:00:09.60,00:00:10.37,Default,,0,0,0,,Cuando alguien \Ncomenta
Dialogue: 0,00:00:10.37,00:00:11.80,Default,,0,0,0,,en vuestra \Npublicación.
Dialogue: 0,00:00:11.80,00:00:12.77,Default,,0,0,0,,Pero si las \Nnotificaciones
Dialogue: 0,00:00:12.77,00:00:14.33,Default,,0,0,0,,no están bien \Nconfiguradas...
Dialogue: 0,00:00:14.33,00:00:16.20,Default,,0,0,0,,nada de eso \Nos llega.
Dialogue: 0,00:00:16.20,00:00:18.40,Default,,0,0,0,,Yo las tengo \Nsiempre a punto.
Dialogue: 0,00:00:18.40,00:00:19.17,Default,,0,0,0,,Y hoy os enseño
Dialogue: 0,00:00:19.17,00:00:20.47,Default,,0,0,0,,cómo se configuran.
Dialogue: 0,00:00:20.47,00:00:21.93,Default,,0,0,0,,Abrís el menú \Nlateral.
Dialogue: 0,00:00:21.93,00:00:23.23,Default,,0,0,0,,Arriba a la derecha
Dialogue: 0,00:00:23.23,00:00:24.00,Default,,0,0,0,,tenéis el icono
Dialogue: 0,00:00:24.00,00:00:25.23,Default,,0,0,0,,de las tres líneas.
Dialogue: 0,00:00:25.23,00:00:26.47,Default,,0,0,0,,Pulsáis y entráis
Dialogue: 0,00:00:26.47,00:00:27.27,Default,,0,0,0,,en ajustes.
Dialogue: 0,00:00:27.27,00:00:27.97,Default,,0,0,0,,Ahí dentro,
Dialogue: 0,00:00:27.97,00:00:28.63,Default,,0,0,0,,notificaciones.
Dialogue: 0,00:00:28.63,00:00:29.97,Default,,0,0,0,,Lo primero \Nque vais a ver...
Dialogue: 0,00:00:29.97,00:00:31.47,Default,,0,0,0,,si la app \Nno tiene permisos,
Dialogue: 0,00:00:31.47,00:00:32.93,Default,,0,0,0,,os aparece \Nuna alerta roja.
Dialogue: 0,00:00:32.93,00:00:35.20,Default,,0,0,0,,Tocáis y \Nlos activáis.
Dialogue: 0,00:00:35.20,00:00:35.87,Default,,0,0,0,,Si no os sale,
Dialogue: 0,00:00:35.87,00:00:36.37,Default,,0,0,0,,tranquilos,
Dialogue: 0,00:00:36.37,00:00:37.37,Default,,0,0,0,,es una función \Nque llegó
Dialogue: 0,00:00:37.37,00:00:39.77,Default,,0,0,0,,con la versión \Nuno punto dos.
Dialogue: 0,00:00:39.77,00:00:40.43,Default,,0,0,0,,Debajo tenéis
Dialogue: 0,00:00:40.43,00:00:41.67,Default,,0,0,0,,todas las categorías
Dialogue: 0,00:00:41.67,00:00:42.43,Default,,0,0,0,,de notificaciones
Dialogue: 0,00:00:42.43,00:00:43.43,Default,,0,0,0,,que envía la app.
Dialogue: 0,00:00:43.43,00:00:44.60,Default,,0,0,0,,Cada una se puede
Dialogue: 0,00:00:44.60,00:00:45.47,Default,,0,0,0,,activar o desactivar
Dialogue: 0,00:00:45.47,00:00:46.83,Default,,0,0,0,,según lo que \Nos interese.
Dialogue: 0,00:00:46.83,00:00:47.83,Default,,0,0,0,,¿Queréis saber
Dialogue: 0,00:00:47.83,00:00:48.83,Default,,0,0,0,,qué hace cada una?
Dialogue: 0,00:00:48.83,00:00:49.67,Default,,0,0,0,,En el menú \Nde la app
Dialogue: 0,00:00:49.67,00:00:51.03,Default,,0,0,0,,tenéis las \Ninstrucciones,
Dialogue: 0,00:00:51.03,00:00:52.73,Default,,0,0,0,,ahí viene \Ntodo explicado.
Dialogue: 0,00:00:52.73,00:00:53.63,Default,,0,0,0,,Por ejemplo,
Dialogue: 0,00:00:53.63,00:00:55.27,Default,,0,0,0,,si no queréis \Nque os avise
Dialogue: 0,00:00:55.27,00:00:56.17,Default,,0,0,0,,cuando una \Npublicación
Dialogue: 0,00:00:56.17,00:00:57.63,Default,,0,0,0,,se archiva \Nautomáticamente...
Dialogue: 0,00:00:57.63,00:00:59.07,Default,,0,0,0,,desactiváis \Nesa categoría
Dialogue: 0,00:00:59.07,00:01:00.03,Default,,0,0,0,,y listo.
Dialogue: 0,00:01:00.03,00:01:01.83,Default,,0,0,0,,No os vuelve \Na llegar.
Dialogue: 0,00:01:01.83,00:01:03.43,Default,,0,0,0,,Y si no veis \Nestas opciones,
Dialogue: 0,00:01:03.43,00:01:04.93,Default,,0,0,0,,actualizad la app
Dialogue: 0,00:01:04.93,00:01:05.80,Default,,0,0,0,,en Play Store.
Dialogue: 0,00:01:05.80,00:01:06.73,Default,,0,0,0,,Vamos mejorando \Ncosas
Dialogue: 0,00:01:06.73,00:01:07.80,Default,,0,0,0,,constantemente.
Dialogue: 0,00:01:07.80,00:01:08.33,Default,,0,0,0,,¿Vosotros tenéis
Dialogue: 0,00:01:08.33,00:01:09.77,Default,,0,0,0,,las notificaciones \Nactivadas?
Dialogue: 0,00:01:09.77,00:01:11.00,Default,,0,0,0,,Contadme cuáles \Nusáis.
Dialogue: 0,00:01:11.00,00:01:11.63,Default,,0,0,0,,Givore.
