Dialogue: 0,00:00:00.00,00:00:00.63,Default,,0,0,0,,Lluvia,
Dialogue: 0,00:00:00.63,00:00:00.97,Default,,0,0,0,,bici,
Dialogue: 0,00:00:00.97,00:00:02.07,Default,,0,0,0,,Valencia...
Dialogue: 0,00:00:02.07,00:00:02.57,Default,,0,0,0,,y algo que
Dialogue: 0,00:00:02.57,00:00:03.23,Default,,0,0,0,,no debería estar
Dialogue: 0,00:00:03.23,00:00:04.03,Default,,0,0,0,,ahí fuera.
Dialogue: 0,00:00:04.03,00:00:04.73,Default,,0,0,0,,Me pilla el agua
Dialogue: 0,00:00:04.73,00:00:05.63,Default,,0,0,0,,pedaleando.
Dialogue: 0,00:00:05.63,00:00:06.53,Default,,0,0,0,,Pero sigo.
Dialogue: 0,00:00:06.53,00:00:06.73,Default,,0,0,0,,Y entre
Dialogue: 0,00:00:06.73,00:00:07.83,Default,,0,0,0,,la lluvia...
Dialogue: 0,00:00:07.83,00:00:08.83,Default,,0,0,0,,una nevera.
Dialogue: 0,00:00:08.83,00:00:09.33,Default,,0,0,0,,Grande.
Dialogue: 0,00:00:09.33,00:00:10.67,Default,,0,0,0,,Aparentemente entera.
Dialogue: 0,00:00:10.67,00:00:11.53,Default,,0,0,0,,Pero cuando
Dialogue: 0,00:00:11.53,00:00:12.43,Default,,0,0,0,,me acerco...
Dialogue: 0,00:00:12.43,00:00:13.47,Default,,0,0,0,,le habían arrancado
Dialogue: 0,00:00:13.47,00:00:13.87,Default,,0,0,0,,el motor.
Dialogue: 0,00:00:13.87,00:00:14.47,Default,,0,0,0,,Alguien la sacó
Dialogue: 0,00:00:14.47,00:00:15.40,Default,,0,0,0,,a la calle.
Dialogue: 0,00:00:15.40,00:00:16.07,Default,,0,0,0,,Y la persona
Dialogue: 0,00:00:16.07,00:00:16.67,Default,,0,0,0,,que la habría
Dialogue: 0,00:00:16.67,00:00:18.27,Default,,0,0,0,,recogido completa...
Dialogue: 0,00:00:18.27,00:00:19.23,Default,,0,0,0,,nunca se enteró
Dialogue: 0,00:00:19.23,00:00:20.23,Default,,0,0,0,,de que existía.
Dialogue: 0,00:00:20.23,00:00:20.87,Default,,0,0,0,,Mientras,
Dialogue: 0,00:00:20.87,00:00:21.77,Default,,0,0,0,,otro pasó
Dialogue: 0,00:00:21.77,00:00:22.17,Default,,0,0,0,,y le sacó
Dialogue: 0,00:00:22.17,00:00:22.77,Default,,0,0,0,,lo único
Dialogue: 0,00:00:22.77,00:00:23.60,Default,,0,0,0,,que podía vender
Dialogue: 0,00:00:23.60,00:00:24.80,Default,,0,0,0,,como chatarra.
Dialogue: 0,00:00:24.80,00:00:25.27,Default,,0,0,0,,Lo que queda
Dialogue: 0,00:00:25.27,00:00:26.03,Default,,0,0,0,,ya no vale nada.
Dialogue: 0,00:00:26.03,00:00:26.67,Default,,0,0,0,,Pero hace
Dialogue: 0,00:00:26.67,00:00:27.40,Default,,0,0,0,,unos días,
Dialogue: 0,00:00:27.40,00:00:27.97,Default,,0,0,0,,esa nevera
Dialogue: 0,00:00:27.97,00:00:28.77,Default,,0,0,0,,enfriaba.
Dialogue: 0,00:00:28.77,00:00:29.23,Default,,0,0,0,,Y hay gente
Dialogue: 0,00:00:29.23,00:00:29.77,Default,,0,0,0,,a pocas calles
Dialogue: 0,00:00:29.77,00:00:30.60,Default,,0,0,0,,que la habría querido
Dialogue: 0,00:00:30.60,00:00:31.37,Default,,0,0,0,,tal cual.
Dialogue: 0,00:00:31.37,00:00:32.07,Default,,0,0,0,,Solo faltaba
Dialogue: 0,00:00:32.07,00:00:32.37,Default,,0,0,0,,el puente
Dialogue: 0,00:00:32.37,00:00:33.23,Default,,0,0,0,,entre los dos.
Dialogue: 0,00:00:33.23,00:00:33.77,Default,,0,0,0,,¿Sabéis cómo
Dialogue: 0,00:00:33.77,00:00:35.03,Default,,0,0,0,,se evita esto?
Dialogue: 0,00:00:35.03,00:00:35.53,Default,,0,0,0,,En Givore,
Dialogue: 0,00:00:35.53,00:00:36.17,Default,,0,0,0,,compartes lo que
Dialogue: 0,00:00:36.17,00:00:37.23,Default,,0,0,0,,ya no necesitas.
Dialogue: 0,00:00:37.23,00:00:37.63,Default,,0,0,0,,Lo subes
Dialogue: 0,00:00:37.63,00:00:38.57,Default,,0,0,0,,en un momento...
Dialogue: 0,00:00:38.57,00:00:39.77,Default,,0,0,0,,y quien esté cerca,
Dialogue: 0,00:00:39.77,00:00:40.77,Default,,0,0,0,,lo encuentra.
Dialogue: 0,00:00:40.77,00:00:41.83,Default,,0,0,0,,Así de directo.
Dialogue: 0,00:00:41.83,00:00:42.83,Default,,0,0,0,,Esa nevera
Dialogue: 0,00:00:42.83,00:00:43.37,Default,,0,0,0,,habría llegado
Dialogue: 0,00:00:43.37,00:00:43.97,Default,,0,0,0,,entera
Dialogue: 0,00:00:43.97,00:00:44.87,Default,,0,0,0,,a otra cocina.
Dialogue: 0,00:00:44.87,00:00:45.57,Default,,0,0,0,,En vez de eso...
Dialogue: 0,00:00:45.57,00:00:46.57,Default,,0,0,0,,chatarra
Dialogue: 0,00:00:46.57,00:00:47.23,Default,,0,0,0,,bajo la lluvia.
Dialogue: 0,00:00:47.23,00:00:48.47,Default,,0,0,0,,Tenerla instalada
Dialogue: 0,00:00:48.47,00:00:49.20,Default,,0,0,0,,merece la pena.
Dialogue: 0,00:00:49.20,00:00:50.27,Default,,0,0,0,,Para cuando tengáis
Dialogue: 0,00:00:50.27,00:00:50.63,Default,,0,0,0,,algo que
Dialogue: 0,00:00:50.63,00:00:51.60,Default,,0,0,0,,ya no uséis.
Dialogue: 0,00:00:51.60,00:00:52.17,Default,,0,0,0,,Givore.
