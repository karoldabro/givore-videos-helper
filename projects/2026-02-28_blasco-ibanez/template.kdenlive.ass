Dialogue: 0,00:00:00.00,00:00:01.17,Default,,0,0,0,,Oye, ven conmigo.
Dialogue: 0,00:00:01.17,00:00:02.43,Default,,0,0,0,,Estoy pedaleando
Dialogue: 0,00:00:02.43,00:00:03.40,Default,,0,0,0,,por uno de los corredores
Dialogue: 0,00:00:03.40,00:00:04.07,Default,,0,0,0,,verdes más bonitos
Dialogue: 0,00:00:04.07,00:00:04.83,Default,,0,0,0,,de Valencia,
Dialogue: 0,00:00:04.83,00:00:06.47,Default,,0,0,0,,la Avenida de Blasco Ibáñez.
Dialogue: 0,00:00:06.47,00:00:08.27,Default,,0,0,0,,Y déjame contarte algo curioso.
Dialogue: 0,00:00:08.27,00:00:09.60,Default,,0,0,0,,Este lugar estaba destinado
Dialogue: 0,00:00:09.60,00:00:10.47,Default,,0,0,0,,a ser el camino
Dialogue: 0,00:00:10.47,00:00:12.07,Default,,0,0,0,,de Valencia hacia el mar.
Dialogue: 0,00:00:12.07,00:00:14.27,Default,,0,0,0,,En 1893, un arquitecto
Dialogue: 0,00:00:14.27,00:00:16.57,Default,,0,0,0,,llamado Casimiro Meseguer
Dialogue: 0,00:00:16.57,00:00:17.73,Default,,0,0,0,,soñó con crear aquí
Dialogue: 0,00:00:17.73,00:00:18.87,Default,,0,0,0,,una ciudad jardín.
Dialogue: 0,00:00:18.87,00:00:19.77,Default,,0,0,0,,¿Te lo imaginas?
Dialogue: 0,00:00:19.77,00:00:21.03,Default,,0,0,0,,La avenida lleva el nombre
Dialogue: 0,00:00:21.03,00:00:22.73,Default,,0,0,0,,de Vicente Blasco Ibáñez,
Dialogue: 0,00:00:22.73,00:00:24.20,Default,,0,0,0,,un escritor valenciano.
Dialogue: 0,00:00:24.20,00:00:25.20,Default,,0,0,0,,Hollywood llevó al cine
Dialogue: 0,00:00:25.20,00:00:25.80,Default,,0,0,0,,sus novelas,
Dialogue: 0,00:00:25.80,00:00:27.07,Default,,0,0,0,,como Sangre y arena
Dialogue: 0,00:00:27.07,00:00:29.20,Default,,0,0,0,,y Los cuatro jinetes del Apocalipsis.
Dialogue: 0,00:00:29.20,00:00:29.77,Default,,0,0,0,,Pero este hombre
Dialogue: 0,00:00:29.77,00:00:31.03,Default,,0,0,0,,no fue solo escritor.
Dialogue: 0,00:00:31.03,00:00:32.13,Default,,0,0,0,,Fue periodista,
Dialogue: 0,00:00:32.13,00:00:34.20,Default,,0,0,0,,político y corresponsal de guerra.
Dialogue: 0,00:00:34.20,00:00:35.73,Default,,0,0,0,,Lo detuvieron en varias ocasiones,
Dialogue: 0,00:00:35.73,00:00:37.03,Default,,0,0,0,,una vez huyó a Paris
Dialogue: 0,00:00:37.03,00:00:38.47,Default,,0,0,0,,disfrazado de pescador,
Dialogue: 0,00:00:38.47,00:00:40.53,Default,,0,0,0,,luchó contra reyes y dictadores.
Dialogue: 0,00:00:40.53,00:00:42.00,Default,,0,0,0,,Y, de alguna manera,
Dialogue: 0,00:00:42.00,00:00:43.47,Default,,0,0,0,,entre todo ese caos,
Dialogue: 0,00:00:43.47,00:00:44.63,Default,,0,0,0,,escribió algunas
Dialogue: 0,00:00:44.63,00:00:45.87,Default,,0,0,0,,de las historias
Dialogue: 0,00:00:45.87,00:00:46.57,Default,,0,0,0,,más hermosas sobre
Dialogue: 0,00:00:46.57,00:00:47.07,Default,,0,0,0,,los agricultores
Dialogue: 0,00:00:47.07,00:00:48.53,Default,,0,0,0,,y pescadores de Valencia,
Dialogue: 0,00:00:48.53,00:00:49.53,Default,,0,0,0,,la gente real,
Dialogue: 0,00:00:49.53,00:00:50.60,Default,,0,0,0,,la vida sencilla.
Dialogue: 0,00:00:50.60,00:00:51.73,Default,,0,0,0,,Creo que le habría
Dialogue: 0,00:00:51.73,00:00:52.67,Default,,0,0,0,,encantado esta avenida.
Dialogue: 0,00:00:52.67,00:00:54.47,Default,,0,0,0,,Pero, sinceramente,
Dialogue: 0,00:00:54.47,00:00:55.53,Default,,0,0,0,,ahora mismo no me importan
Dialogue: 0,00:00:55.53,00:00:56.87,Default,,0,0,0,,los libros de historia.
Dialogue: 0,00:00:56.87,00:00:57.87,Default,,0,0,0,,Mira esto.
Dialogue: 0,00:00:57.87,00:00:59.43,Default,,0,0,0,,Árboles por todas partes
Dialogue: 0,00:00:59.43,00:01:00.00,Default,,0,0,0,,creando este
Dialogue: 0,00:01:00.00,00:01:01.43,Default,,0,0,0,,túnel verde sobre mí,
Dialogue: 0,00:01:01.43,00:01:02.83,Default,,0,0,0,,y estatuas asomando
Dialogue: 0,00:01:02.83,00:01:03.93,Default,,0,0,0,,entre las hojas.
Dialogue: 0,00:01:03.93,00:01:04.77,Default,,0,0,0,,¿Sabes qué?
Dialogue: 0,00:01:04.77,00:01:05.87,Default,,0,0,0,,Me siento mejor.
Dialogue: 0,00:01:05.87,00:01:07.03,Default,,0,0,0,,Solo esta paz,
Dialogue: 0,00:01:07.03,00:01:08.17,Default,,0,0,0,,aire fresco,
Dialogue: 0,00:01:08.17,00:01:09.20,Default,,0,0,0,,mi bici,
Dialogue: 0,00:01:09.20,00:01:10.53,Default,,0,0,0,,sin prisas.
Dialogue: 0,00:01:10.53,00:01:11.07,Default,,0,0,0,,Esta avenida
Dialogue: 0,00:01:11.07,00:01:12.63,Default,,0,0,0,,se extiende casi tres kilómetros
Dialogue: 0,00:01:12.63,00:01:13.93,Default,,0,0,0,,desde los Jardines del Real
Dialogue: 0,00:01:13.93,00:01:14.77,Default,,0,0,0,,hacia el mar,
Dialogue: 0,00:01:14.77,00:01:16.00,Default,,0,0,0,,hasta un barrio llamado
Dialogue: 0,00:01:16.00,00:01:16.80,Default,,0,0,0,,El Cabanyal.
Dialogue: 0,00:01:16.80,00:01:17.83,Default,,0,0,0,,Tres kilómetros
Dialogue: 0,00:01:17.83,00:01:18.97,Default,,0,0,0,,de calma pura,
Dialogue: 0,00:01:18.97,00:01:20.03,Default,,0,0,0,,y hoy solo te estoy
Dialogue: 0,00:01:20.03,00:01:21.37,Default,,0,0,0,,enseñando unos pocos
Dialogue: 0,00:01:21.37,00:01:22.23,Default,,0,0,0,,cientos de metros.
Dialogue: 0,00:01:22.23,00:01:23.87,Default,,0,0,0,,¿Sabes qué es lo que me encanta
Dialogue: 0,00:01:23.87,00:01:25.13,Default,,0,0,0,,de pedalear por sitios así?
Dialogue: 0,00:01:25.13,00:01:26.53,Default,,0,0,0,,Que te fijas en cosas:
Dialogue: 0,00:01:26.53,00:01:27.83,Default,,0,0,0,,cosas antiguas,
Dialogue: 0,00:01:27.83,00:01:28.53,Default,,0,0,0,,olvidadas,
Dialogue: 0,00:01:28.53,00:01:29.47,Default,,0,0,0,,cosas que la gente
Dialogue: 0,00:01:29.47,00:01:30.20,Default,,0,0,0,,deja atrás
Dialogue: 0,00:01:30.20,00:01:30.73,Default,,0,0,0,,esperando
Dialogue: 0,00:01:30.73,00:01:32.57,Default,,0,0,0,,que alguien nuevo las encuentre.
Dialogue: 0,00:01:32.57,00:01:33.33,Default,,0,0,0,,Hablando de eso,
Dialogue: 0,00:01:33.33,00:01:33.93,Default,,0,0,0,,he estado usando
Dialogue: 0,00:01:33.93,00:01:34.63,Default,,0,0,0,,una app llamada
Dialogue: 0,00:01:34.63,00:01:35.33,Default,,0,0,0,,Givore.
Dialogue: 0,00:01:35.33,00:01:36.43,Default,,0,0,0,,La gente comparte
Dialogue: 0,00:01:36.43,00:01:38.07,Default,,0,0,0,,cosas que ya no necesita:
Dialogue: 0,00:01:38.07,00:01:39.27,Default,,0,0,0,,muebles, ropa,
Dialogue: 0,00:01:39.27,00:01:41.40,Default,,0,0,0,,pequeños tesoros al azar.
Dialogue: 0,00:01:41.40,00:01:42.07,Default,,0,0,0,,Es como otro tipo
Dialogue: 0,00:01:42.07,00:01:43.43,Default,,0,0,0,,de búsqueda del tesoro,
Dialogue: 0,00:01:43.43,00:01:45.00,Default,,0,0,0,,darles una segunda vida
Dialogue: 0,00:01:45.00,00:01:46.23,Default,,0,0,0,,en lugar de tirarlas.
Dialogue: 0,00:01:46.23,00:01:47.13,Default,,0,0,0,,En cierto modo encaja
Dialogue: 0,00:01:47.13,00:01:48.03,Default,,0,0,0,,con este lugar.
Dialogue: 0,00:01:48.03,00:01:48.87,Default,,0,0,0,,Sueños antiguos,
Dialogue: 0,00:01:48.87,00:01:50.23,Default,,0,0,0,,nuevo propósito.
Dialogue: 0,00:01:50.23,00:01:50.63,Default,,0,0,0,,En fin,
Dialogue: 0,00:01:50.63,00:01:52.20,Default,,0,0,0,,debería seguir pedaleando,
Dialogue: 0,00:01:52.20,00:01:53.17,Default,,0,0,0,,pero quédate conmigo.
Dialogue: 0,00:01:53.17,00:01:54.57,Default,,0,0,0,,El mar nos espera.
