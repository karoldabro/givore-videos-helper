      "clips": [
        {
          "clip_id": "sub0",
          "text": "Lo que para\nunos sobra,",
          "position": 0.0,
          "in": 0.0,
          "out": 1.2,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "para otros es\njusto lo que necesitan.",
          "position": 1.2,
          "in": 0.0,
          "out": 2.5599999999999996,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Y casi nunca\nse encuentran.",
          "position": 3.76,
          "in": 0.0,
          "out": 1.4800000000000004,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Porque las cosas\nno esperan.",
          "position": 5.24,
          "in": 0.0,
          "out": 1.4799999999999995,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "Hoy est\u00e1n ah\u00ed...",
          "position": 6.72,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "ma\u00f1ana ya no.",
          "position": 7.72,
          "in": 0.0,
          "out": 0.8400000000000007,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Se las lleva\nel cami\u00f3n,",
          "position": 8.56,
          "in": 0.0,
          "out": 1.08,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "la lluvia,\nel tiempo.",
          "position": 9.64,
          "in": 0.0,
          "out": 1.4399999999999995,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Muebles, aparatos,\nobjetos \u00fatiles",
          "position": 11.08,
          "in": 0.0,
          "out": 2.08,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "que tienen\nlas horas contadas",
          "position": 13.16,
          "in": 0.0,
          "out": 1.2799999999999994,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "en la acera.",
          "position": 14.44,
          "in": 0.0,
          "out": 0.9199999999999999,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Y lo bonito es\nque cuando conectas",
          "position": 15.36,
          "in": 0.0,
          "out": 1.3599999999999994,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "a vecinos...",
          "position": 16.72,
          "in": 0.0,
          "out": 0.7200000000000024,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "pasan cosas bonitas.",
          "position": 17.44,
          "in": 0.0,
          "out": 1.6799999999999997,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Gente que\nno se conoce,",
          "position": 19.12,
          "in": 0.0,
          "out": 1.3599999999999994,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "ayud\u00e1ndose\nsin saberlo.",
          "position": 20.48,
          "in": 0.0,
          "out": 1.5599999999999987,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "Compartiendo sin esperar\nnada a cambio.",
          "position": 22.04,
          "in": 0.0,
          "out": 2.7600000000000016,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "Mirad lo\nque hago.",
          "position": 24.8,
          "in": 0.0,
          "out": 1.0399999999999991,
          "filters": []
        },
        {
          "clip_id": "sub18",
          "text": "Givore.",
          "position": 25.84,
          "in": 0.0,
          "out": 0.7600000000000016,
          "filters": []
        },
        {
          "clip_id": "sub19",
          "text": "Una app donde\ncompartes lo que",
          "position": 26.6,
          "in": 0.0,
          "out": 1.3599999999999994,
          "filters": []
        },
        {
          "clip_id": "sub20",
          "text": "te sobra",
          "position": 27.96,
          "in": 0.0,
          "out": 0.5999999999999979,
          "filters": []
        },
        {
          "clip_id": "sub21",
          "text": "y descubres lo\nque otros ofrecen.",
          "position": 28.56,
          "in": 0.0,
          "out": 1.6000000000000014,
          "filters": []
        },
        {
          "clip_id": "sub22",
          "text": "Foto, t\u00edtulo,",
          "position": 30.16,
          "in": 0.0,
          "out": 1.3999999999999986,
          "filters": []
        },
        {
          "clip_id": "sub23",
          "text": "y ya est\u00e1 visible",
          "position": 31.56,
          "in": 0.0,
          "out": 0.6800000000000033,
          "filters": []
        },
        {
          "clip_id": "sub24",
          "text": "para gente\nde tu zona.",
          "position": 32.24,
          "in": 0.0,
          "out": 1.1999999999999957,
          "filters": []
        },
        {
          "clip_id": "sub25",
          "text": "La comunidad\nest\u00e1 arrancando.",
          "position": 33.44,
          "in": 0.0,
          "out": 1.7600000000000051,
          "filters": []
        },
        {
          "clip_id": "sub26",
          "text": "Somos pocos todav\u00eda,",
          "position": 35.2,
          "in": 0.0,
          "out": 1.0399999999999991,
          "filters": []
        },
        {
          "clip_id": "sub27",
          "text": "pero cada persona\nque se une",
          "position": 36.24,
          "in": 0.0,
          "out": 1.2800000000000011,
          "filters": []
        },
        {
          "clip_id": "sub28",
          "text": "cambia algo.",
          "position": 37.52,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub29",
          "text": "Ciudad a ciudad.",
          "position": 38.52,
          "in": 0.0,
          "out": 1.3599999999999994,
          "filters": []
        },
        {
          "clip_id": "sub30",
          "text": "Barrio a barrio.",
          "position": 39.88,
          "in": 0.0,
          "out": 0.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub31",
          "text": "Porque compartir\na tiempo",
          "position": 40.84,
          "in": 0.0,
          "out": 1.0399999999999991,
          "filters": []
        },
        {
          "clip_id": "sub32",
          "text": "es mejor que encontrar\ndemasiado tarde.",
          "position": 41.88,
          "in": 0.0,
          "out": 2.0,
          "filters": []
        },
        {
          "clip_id": "sub33",
          "text": "Si os mola\nla idea...",
