    {
      "id": 2,
      "name": "Subtitles",
      "type": "subtitle",
      "mute": false,
      "hide": false,
      "locked": false,
      "clips": [
        {
          "clip_id": "sub0",
          "text": "Hoy me he recorrido\nmedia ciudad en bici...",
          "position": 0.0,
          "in": 0.0,
          "out": 2.28,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "pensando en una cosa.",
          "position": 2.28,
          "in": 0.0,
          "out": 0.9600000000000004,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Cada d\u00eda se pierden\nobjetos \u00fatiles",
          "position": 3.24,
          "in": 0.0,
          "out": 2.84,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "en nuestras calles.",
          "position": 6.08,
          "in": 0.0,
          "out": 0.7999999999999998,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "Cosas que funcionan.",
          "position": 6.88,
          "in": 0.0,
          "out": 0.9199999999999999,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "Cosas que valen.",
          "position": 7.8,
          "in": 0.0,
          "out": 1.3199999999999994,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Ah\u00ed tiradas,\na plena vista.",
          "position": 9.12,
          "in": 0.0,
          "out": 2.200000000000001,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Y todo el mundo\npasa de largo.",
          "position": 11.32,
          "in": 0.0,
          "out": 1.92,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Y lo incre\u00edble es",
          "position": 13.24,
          "in": 0.0,
          "out": 0.7200000000000006,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "que a un par\nde calles...",
          "position": 13.96,
          "in": 0.0,
          "out": 1.4799999999999986,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "hay alguien que\nlo aprovechar\u00eda encantado.",
          "position": 15.44,
          "in": 0.0,
          "out": 2.480000000000002,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Solo falta\nque lo vea.",
          "position": 17.92,
          "in": 0.0,
          "out": 1.7199999999999989,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "Y sab\u00e9is qu\u00e9\nhago yo",
          "position": 19.64,
          "in": 0.0,
          "out": 0.8000000000000007,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "cuando pienso\nen esto?",
          "position": 20.44,
          "in": 0.0,
          "out": 1.2399999999999984,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Uso Givore.",
          "position": 21.68,
          "in": 0.0,
          "out": 0.9200000000000017,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "Una app donde\ncompartes lo que",
          "position": 22.6,
          "in": 0.0,
          "out": 1.2399999999999984,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "ya no usas",
          "position": 23.84,
          "in": 0.0,
          "out": 0.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "y descubres lo\nque otros quieren dar.",
          "position": 24.68,
          "in": 0.0,
          "out": 2.0,
          "filters": []
        },
        {
          "clip_id": "sub18",
          "text": "As\u00ed de simple.",
          "position": 26.68,
          "in": 0.0,
          "out": 0.9200000000000017,
          "filters": []
        },
        {
          "clip_id": "sub19",
          "text": "Foto, t\u00edtulo, listo.",
          "position": 27.6,
          "in": 0.0,
          "out": 1.759999999999998,
          "filters": []
        },
        {
          "clip_id": "sub20",
          "text": "Os soy sincero.",
          "position": 29.36,
          "in": 0.0,
          "out": 1.1600000000000001,
          "filters": []
        },
        {
          "clip_id": "sub21",
          "text": "Givore acaba\nde nacer.",
          "position": 30.52,
          "in": 0.0,
          "out": 1.4800000000000004,
          "filters": []
        },
        {
          "clip_id": "sub22",
          "text": "La comunidad todav\u00eda\nes peque\u00f1a.",
          "position": 32.0,
          "in": 0.0,
          "out": 1.6000000000000014,
          "filters": []
        },
        {
          "clip_id": "sub23",
          "text": "Pero cada persona\nque entra",
          "position": 33.6,
          "in": 0.0,
          "out": 0.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub24",
          "text": "hace que\nfuncione mejor.",
          "position": 34.56,
          "in": 0.0,
          "out": 1.519999999999996,
          "filters": []
        },
        {
          "clip_id": "sub25",
          "text": "M\u00e1s cosas compartidas.",
          "position": 36.08,
          "in": 0.0,
          "out": 1.3599999999999994,
          "filters": []
        },
        {
          "clip_id": "sub26",
          "text": "M\u00e1s vecinos conectados.",
          "position": 37.44,
          "in": 0.0,
          "out": 1.480000000000004,
          "filters": []
        },
        {
          "clip_id": "sub27",
          "text": "Porque donar a tiempo",
          "position": 38.92,
          "in": 0.0,
          "out": 1.3200000000000003,
          "filters": []
        },
        {
          "clip_id": "sub28",
          "text": "siempre es mejor\nque abandonar",
          "position": 40.24,
          "in": 0.0,
          "out": 1.3599999999999994,
          "filters": []
        },
        {
          "clip_id": "sub29",
          "text": "en la calle.",
          "position": 41.6,
          "in": 0.0,
          "out": 0.519999999999996,
          "filters": []
        },
        {
          "clip_id": "sub30",
          "text": "Si cre\u00e9is en esto...",
          "position": 42.12,
          "in": 0.0,
          "out": 1.2000000000000028,
          "filters": []
        },
        {
          "clip_id": "sub31",
          "text": "pasad la voz.",
          "position": 43.32,
          "in": 0.0,
          "out": 1.0799999999999983,
          "filters": []
        },
        {
          "clip_id": "sub32",
          "text": "Que m\u00e1s gente\nlo sepa.",
          "position": 44.4,
          "in": 0.0,
          "out": 1.480000000000004,
          "filters": []
        }
