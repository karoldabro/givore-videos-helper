    {
      "id": 2,
      "name": "Subtitles",
      "type": "subtitle",
      "mute": false,
      "hide": false,
      "locked": false,
      "clips": [
        {
          "clip_id": "sub0",
          "text": "Tres cosas.",
          "position": 0.0,
          "in": 0.0,
          "out": 0.76,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "Tres cosas he pensado\nhoy mientras iba en bici.",
          "position": 0.76,
          "in": 0.0,
          "out": 3.08,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Una.",
          "position": 3.84,
          "in": 0.0,
          "out": 0.6000000000000005,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Que en este barrio",
          "position": 4.44,
          "in": 0.0,
          "out": 1.2799999999999994,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "hay alguien\nque necesita",
          "position": 5.72,
          "in": 0.0,
          "out": 1.12,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "justo lo que otro\nquiere tirar.",
          "position": 6.84,
          "in": 0.0,
          "out": 1.92,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Dos.",
          "position": 8.76,
          "in": 0.0,
          "out": 0.6400000000000006,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Que la persona que\ndej\u00f3 algo en la acera",
          "position": 9.4,
          "in": 0.0,
          "out": 1.6399999999999988,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "y la persona\nque lo busca...",
          "position": 11.04,
          "in": 0.0,
          "out": 1.4000000000000004,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "a lo mejor viven\nen la misma calle.",
          "position": 12.44,
          "in": 0.0,
          "out": 1.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "Y tres.",
          "position": 14.28,
          "in": 0.0,
          "out": 0.7200000000000006,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Que solo falta\nel puente",
          "position": 15.0,
          "in": 0.0,
          "out": 0.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "entre los dos.",
          "position": 15.96,
          "in": 0.0,
          "out": 0.9199999999999982,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "Uno comparte,\notro descubre.",
          "position": 16.88,
          "in": 0.0,
          "out": 1.6000000000000014,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Vecinos conectando\nsin conocerse.",
          "position": 18.48,
          "in": 0.0,
          "out": 2.039999999999999,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "As\u00ed de simple.",
          "position": 20.52,
          "in": 0.0,
          "out": 1.1999999999999993,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "Y aqu\u00ed es donde\nentramos todos.",
          "position": 21.72,
          "in": 0.0,
          "out": 1.2800000000000011,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "Givore.",
          "position": 23.0,
          "in": 0.0,
          "out": 0.3999999999999986,
          "filters": []
        },
        {
          "clip_id": "sub18",
          "text": "Compartes lo\nque te sobra.",
          "position": 23.4,
          "in": 0.0,
          "out": 2.280000000000001,
          "filters": []
        },
        {
          "clip_id": "sub19",
          "text": "Descubres lo que\notros ofrecen cerca.",
          "position": 25.68,
          "in": 0.0,
          "out": 2.039999999999999,
          "filters": []
        },
        {
          "clip_id": "sub20",
          "text": "Sin dinero.",
          "position": 27.72,
          "in": 0.0,
          "out": 1.0800000000000018,
          "filters": []
        },
        {
          "clip_id": "sub21",
          "text": "Sin rollos.",
          "position": 28.8,
          "in": 0.0,
          "out": 1.0799999999999983,
          "filters": []
        },
        {
          "clip_id": "sub22",
          "text": "Foto, t\u00edtulo,",
          "position": 29.88,
          "in": 0.0,
          "out": 1.1600000000000001,
          "filters": []
        },
        {
          "clip_id": "sub23",
          "text": "y en segundos lo ve\ngente de tu zona.",
          "position": 31.04,
          "in": 0.0,
          "out": 1.8800000000000026,
          "filters": []
        },
        {
          "clip_id": "sub24",
          "text": "Pero voy a\nser honesto.",
          "position": 32.92,
          "in": 0.0,
          "out": 1.7199999999999989,
          "filters": []
        },
        {
          "clip_id": "sub25",
          "text": "Esto acaba\nde empezar.",
          "position": 34.64,
          "in": 0.0,
          "out": 1.3200000000000003,
          "filters": []
        },
        {
          "clip_id": "sub26",
          "text": "La comunidad\ncrece despacio.",
          "position": 35.96,
          "in": 0.0,
          "out": 1.240000000000002,
          "filters": []
        },
        {
          "clip_id": "sub27",
          "text": "Cada persona que\nse une lo hace",
          "position": 37.2,
          "in": 0.0,
          "out": 1.759999999999998,
          "filters": []
        },
        {
          "clip_id": "sub28",
          "text": "m\u00e1s fuerte.",
          "position": 38.96,
          "in": 0.0,
          "out": 0.7999999999999972,
          "filters": []
        },
        {
          "clip_id": "sub29",
          "text": "Cada objeto compartido",
          "position": 39.76,
          "in": 0.0,
          "out": 1.3599999999999994,
          "filters": []
        },
        {
          "clip_id": "sub30",
          "text": "es uno menos perdido.",
          "position": 41.12,
          "in": 0.0,
          "out": 1.0399999999999991,
          "filters": []
        },
        {
          "clip_id": "sub31",
          "text": "Porque compartir\nantes de tirar...",
          "position": 42.16,
          "in": 0.0,
          "out": 2.0400000000000063,
          "filters": []
        },
        {
          "clip_id": "sub32",
          "text": "eso s\u00ed cambia\nlas cosas.",
          "position": 44.2,
          "in": 0.0,
          "out": 1.0399999999999991,
          "filters": []
        },
        {
          "clip_id": "sub33",
          "text": "Pens\u00e1is igual?",
          "position": 45.24,
          "in": 0.0,
          "out": 0.7199999999999989,
          "filters": []
        },
        {
          "clip_id": "sub34",
          "text": "Cont\u00e1dmelo\nen comentarios.",
          "position": 45.96,
          "in": 0.0,
          "out": 1.0399999999999991,
          "filters": []
        },
        {
          "clip_id": "sub35",
          "text": "Quiero leer\nvuestras historias.",
          "position": 47.0,
          "in": 0.0,
          "out": 1.7999999999999972,
          "filters": []
        }
