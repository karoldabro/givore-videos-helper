      "clips": [
        {
          "clip_id": "sub0",
          "text": "Si viv\u00eds\nen Espa\u00f1a...",
          "position": 0.0,
          "in": 0.0,
          "out": 2.2,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "ten\u00e9is que\nver esto.",
          "position": 2.2,
          "in": 0.0,
          "out": 1.4,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Cosas perfectamente buenas",
          "position": 3.6,
          "in": 0.0,
          "out": 1.3599999999999999,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "que acaban\nen la acera.",
          "position": 4.96,
          "in": 0.0,
          "out": 1.3600000000000003,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "Y lo triste es",
          "position": 6.32,
          "in": 0.0,
          "out": 1.3999999999999995,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "que si se hubieran\ncompartido a tiempo...",
          "position": 7.72,
          "in": 0.0,
          "out": 2.000000000000001,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "habr\u00edan llegado directas",
          "position": 9.72,
          "in": 0.0,
          "out": 1.2400000000000002,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "a quien\nlas necesita.",
          "position": 10.96,
          "in": 0.0,
          "out": 1.4399999999999995,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "En mejor estado.",
          "position": 12.4,
          "in": 0.0,
          "out": 0.7199999999999989,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Sin mojarse.",
          "position": 13.12,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "Sin romperse.",
          "position": 14.12,
          "in": 0.0,
          "out": 1.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Pues eso\ntiene soluci\u00f3n.",
          "position": 15.24,
          "in": 0.0,
          "out": 1.4799999999999986,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "Y es m\u00e1s simple\nde lo que pens\u00e1is.",
          "position": 16.72,
          "in": 0.0,
          "out": 1.8000000000000007,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "Se llama Givore.",
          "position": 18.52,
          "in": 0.0,
          "out": 0.7600000000000016,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Publicas lo que\nquieres dar...",
          "position": 19.28,
          "in": 0.0,
          "out": 1.9199999999999982,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "y descubres lo\nque otros ofrecen",
          "position": 21.2,
          "in": 0.0,
          "out": 1.4000000000000021,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "cerca de ti.",
          "position": 22.6,
          "in": 0.0,
          "out": 0.7199999999999989,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "Sin dinero.",
          "position": 23.32,
          "in": 0.0,
          "out": 0.5599999999999987,
          "filters": []
        },
        {
          "clip_id": "sub18",
          "text": "Sin complicaciones.",
          "position": 23.88,
          "in": 0.0,
          "out": 1.1999999999999993,
          "filters": []
        },
        {
          "clip_id": "sub19",
          "text": "Solo conectar\na quien tiene",
          "position": 25.08,
          "in": 0.0,
          "out": 1.1600000000000001,
          "filters": []
        },
        {
          "clip_id": "sub20",
          "text": "con quien necesita.",
          "position": 26.24,
          "in": 0.0,
          "out": 0.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub21",
          "text": "Pero os cuento\nla verdad.",
          "position": 27.08,
          "in": 0.0,
          "out": 1.8800000000000026,
          "filters": []
        },
        {
          "clip_id": "sub22",
          "text": "Givore es nueva.",
          "position": 28.96,
          "in": 0.0,
          "out": 1.1999999999999993,
          "filters": []
        },
        {
          "clip_id": "sub23",
          "text": "La comunidad se est\u00e1\nformando ahora mismo.",
          "position": 30.16,
          "in": 0.0,
          "out": 1.9999999999999964,
          "filters": []
        },
        {
          "clip_id": "sub24",
          "text": "Poco a poco.",
          "position": 32.16,
          "in": 0.0,
          "out": 1.2800000000000011,
          "filters": []
        },
        {
          "clip_id": "sub25",
          "text": "Y cada persona\nque se suma",
          "position": 33.44,
          "in": 0.0,
          "out": 1.1200000000000045,
          "filters": []
        },
        {
          "clip_id": "sub26",
          "text": "lo hace m\u00e1s \u00fatil\npara todos.",
          "position": 34.56,
          "in": 0.0,
          "out": 1.3200000000000003,
          "filters": []
        },
        {
          "clip_id": "sub27",
          "text": "Porque lo ideal",
          "position": 35.88,
          "in": 0.0,
          "out": 0.759999999999998,
          "filters": []
        },
        {
          "clip_id": "sub28",
          "text": "no es rescatar cosas\nde la calle.",
          "position": 36.64,
          "in": 0.0,
          "out": 1.6799999999999997,
          "filters": []
        },
        {
          "clip_id": "sub29",
          "text": "Lo ideal es\nque se compartan",
          "position": 38.32,
          "in": 0.0,
          "out": 1.0799999999999983,
          "filters": []
        },
        {
          "clip_id": "sub30",
          "text": "antes de acabar ah\u00ed.",
          "position": 39.4,
          "in": 0.0,
          "out": 1.1600000000000037,
          "filters": []
        },
        {
          "clip_id": "sub31",
          "text": "Guardad este v\u00eddeo",
          "position": 40.56,
          "in": 0.0,
          "out": 1.0399999999999991,
          "filters": []
        },
        {
          "clip_id": "sub32",
          "text": "y compartidlo\ncon alguien",
          "position": 41.6,
          "in": 0.0,
          "out": 1.1199999999999974,
          "filters": []
        },
        {
          "clip_id": "sub33",
          "text": "que le pueda\ninteresar.",
          "position": 42.72,
          "in": 0.0,
          "out": 1.1600000000000037,
          "filters": []
        },
        {
          "clip_id": "sub34",
          "text": "As\u00ed crecemos juntos.",
          "position": 43.88,
          "in": 0.0,
          "out": 1.279999999999994,
          "filters": []
        }
