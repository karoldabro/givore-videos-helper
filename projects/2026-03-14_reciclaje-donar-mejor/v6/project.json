      "clips": [
        {
          "clip_id": "sub0",
          "text": "D\u00eda uno de algo",
          "position": 0.0,
          "in": 0.0,
          "out": 1.08,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "que puede cambiar",
          "position": 1.08,
          "in": 0.0,
          "out": 0.76,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "c\u00f3mo compartimos\nlas cosas.",
          "position": 1.84,
          "in": 0.0,
          "out": 1.8800000000000001,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Tu vecino de\ndos calles m\u00e1s all\u00e1",
          "position": 3.72,
          "in": 0.0,
          "out": 1.6,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "puede que necesite",
          "position": 5.32,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "justo lo que\na ti te sobra.",
          "position": 6.32,
          "in": 0.0,
          "out": 1.7599999999999998,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Y no lo sabe.",
          "position": 8.08,
          "in": 0.0,
          "out": 0.8800000000000008,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Nadie lo sabe.",
          "position": 8.96,
          "in": 0.0,
          "out": 1.0799999999999983,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Porque no existe\nesa conexi\u00f3n.",
          "position": 10.04,
          "in": 0.0,
          "out": 1.7200000000000006,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Muebles, aparatos,",
          "position": 11.76,
          "in": 0.0,
          "out": 1.2799999999999994,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "cosas que funcionan...",
          "position": 13.04,
          "in": 0.0,
          "out": 1.4400000000000013,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "esperando en aceras\nde toda Espa\u00f1a.",
          "position": 14.48,
          "in": 0.0,
          "out": 2.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "Y a unos metros,",
          "position": 16.6,
          "in": 0.0,
          "out": 0.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "alguien buscando\nexactamente eso.",
          "position": 17.44,
          "in": 0.0,
          "out": 1.4800000000000004,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Pues por eso",
          "position": 18.92,
          "in": 0.0,
          "out": 0.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "siempre llevo el\nm\u00f3vil preparado.",
          "position": 19.76,
          "in": 0.0,
          "out": 1.7999999999999972,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "Givore.",
          "position": 21.56,
          "in": 0.0,
          "out": 0.8000000000000007,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "Una app donde publicas",
          "position": 22.36,
          "in": 0.0,
          "out": 1.1600000000000001,
          "filters": []
        },
        {
          "clip_id": "sub18",
          "text": "lo que ya\nno necesitas",
          "position": 23.52,
          "in": 0.0,
          "out": 0.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub19",
          "text": "y descubres lo\nque otros quieren dar.",
          "position": 24.48,
          "in": 0.0,
          "out": 1.759999999999998,
          "filters": []
        },
        {
          "clip_id": "sub20",
          "text": "R\u00e1pido.",
          "position": 26.24,
          "in": 0.0,
          "out": 0.4400000000000013,
          "filters": []
        },
        {
          "clip_id": "sub21",
          "text": "F\u00e1cil.",
          "position": 26.68,
          "in": 0.0,
          "out": 0.3999999999999986,
          "filters": []
        },
        {
          "clip_id": "sub22",
          "text": "Sin complicaciones.",
          "position": 27.08,
          "in": 0.0,
          "out": 0.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub23",
          "text": "Pero escuchad.",
          "position": 28.04,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub24",
          "text": "Givore es nueva.",
          "position": 29.04,
          "in": 0.0,
          "out": 1.4400000000000013,
          "filters": []
        },
        {
          "clip_id": "sub25",
          "text": "Muy nueva.",
          "position": 30.48,
          "in": 0.0,
          "out": 0.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub26",
          "text": "La comunidad se est\u00e1\nformando ahora.",
          "position": 31.44,
          "in": 0.0,
          "out": 1.9599999999999973,
          "filters": []
        },
        {
          "clip_id": "sub27",
          "text": "Y necesitamos gente\nque crea en esto.",
          "position": 33.4,
          "in": 0.0,
          "out": 1.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub28",
          "text": "Gente que prefiera\ncompartir",
          "position": 35.36,
          "in": 0.0,
          "out": 1.6799999999999997,
          "filters": []
        },
        {
          "clip_id": "sub29",
          "text": "antes que tirar.",
          "position": 37.04,
          "in": 0.0,
          "out": 0.5600000000000023,
          "filters": []
        },
        {
          "clip_id": "sub30",
          "text": "Todo puede tener\nuna segunda vida.",
          "position": 37.6,
          "in": 0.0,
          "out": 2.1599999999999966,
          "filters": []
        },
        {
          "clip_id": "sub31",
          "text": "Solo falta el puente",
          "position": 39.76,
          "in": 0.0,
          "out": 0.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub32",
          "text": "entre quien lo deja",
          "position": 40.72,
          "in": 0.0,
          "out": 0.9200000000000017,
          "filters": []
        },
        {
          "clip_id": "sub33",
          "text": "y quien lo quiere.",
