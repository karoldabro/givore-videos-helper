      "clips": [
        {
          "clip_id": "sub0",
          "text": "Esto es lo que pasa\ncada d\u00eda",
          "position": 0.0,
          "in": 0.0,
          "out": 1.28,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "en las calles\nde Espa\u00f1a.",
          "position": 1.28,
          "in": 0.0,
          "out": 1.24,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Cosas \u00fatiles.",
          "position": 2.52,
          "in": 0.0,
          "out": 0.7999999999999998,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Abandonadas.",
          "position": 3.32,
          "in": 0.0,
          "out": 1.0400000000000005,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "A plena vista.",
          "position": 4.36,
          "in": 0.0,
          "out": 1.08,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "Y lo curioso es",
          "position": 5.44,
          "in": 0.0,
          "out": 0.9199999999999999,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "que esto podr\u00eda haberse\ncompartido f\u00e1cilmente.",
          "position": 6.36,
          "in": 0.0,
          "out": 2.759999999999999,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Si quien lo dej\u00f3",
          "position": 9.12,
          "in": 0.0,
          "out": 0.5600000000000005,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "hubiera sabido que\nalguien lo quer\u00eda...",
          "position": 9.68,
          "in": 0.0,
          "out": 2.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "no estar\u00eda aqu\u00ed.",
          "position": 11.8,
          "in": 0.0,
          "out": 1.1999999999999993,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "Una cosa menos\nen la basura",
          "position": 13.0,
          "in": 0.0,
          "out": 1.4399999999999995,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "es una cosa\nm\u00e1s aprovechada.",
          "position": 14.44,
          "in": 0.0,
          "out": 1.6399999999999988,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "Cada objeto que\nse comparte",
          "position": 16.08,
          "in": 0.0,
          "out": 1.7200000000000024,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "es uno menos que acaba\ndonde no deber\u00eda.",
          "position": 17.8,
          "in": 0.0,
          "out": 2.16,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Os ense\u00f1o.",
          "position": 19.96,
          "in": 0.0,
          "out": 0.8000000000000007,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "Givore.",
          "position": 20.76,
          "in": 0.0,
          "out": 0.3999999999999986,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "Publicas lo que\nte sobra en casa.",
          "position": 21.16,
          "in": 0.0,
          "out": 2.5199999999999996,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "Alguien de tu barrio\nlo descubre.",
          "position": 23.68,
          "in": 0.0,
          "out": 1.6799999999999997,
          "filters": []
        },
        {
          "clip_id": "sub18",
          "text": "Foto, t\u00edtulo,",
          "position": 25.36,
          "in": 0.0,
          "out": 1.5199999999999996,
          "filters": []
        },
        {
          "clip_id": "sub19",
          "text": "y en segundos ya lo ve\ngente cerca de ti.",
          "position": 26.88,
          "in": 0.0,
          "out": 2.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub20",
          "text": "Sin dinero.",
          "position": 29.0,
          "in": 0.0,
          "out": 0.879999999999999,
          "filters": []
        },
        {
          "clip_id": "sub21",
          "text": "Sin intermediarios.",
          "position": 29.88,
          "in": 0.0,
          "out": 1.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub22",
          "text": "Pero vamos a\nser realistas.",
          "position": 31.0,
          "in": 0.0,
          "out": 2.039999999999999,
          "filters": []
        },
        {
          "clip_id": "sub23",
          "text": "Givore acaba\nde arrancar.",
          "position": 33.04,
          "in": 0.0,
          "out": 1.5200000000000031,
          "filters": []
        },
        {
          "clip_id": "sub24",
          "text": "La comunidad se est\u00e1\nformando poco a poco.",
          "position": 34.56,
          "in": 0.0,
          "out": 2.0,
          "filters": []
        },
        {
          "clip_id": "sub25",
          "text": "Pero cada vecino\nque se une",
          "position": 36.56,
          "in": 0.0,
          "out": 1.4399999999999977,
          "filters": []
        },
        {
          "clip_id": "sub26",
          "text": "hace la diferencia.",
          "position": 38.0,
          "in": 0.0,
          "out": 1.759999999999998,
          "filters": []
        },
        {
          "clip_id": "sub27",
          "text": "M\u00e1s gente compartiendo,",
          "position": 39.76,
          "in": 0.0,
          "out": 1.1600000000000037,
          "filters": []
        },
        {
          "clip_id": "sub28",
          "text": "menos cosas perdidas.",
          "position": 40.92,
          "in": 0.0,
          "out": 1.3999999999999986,
          "filters": []
        },
        {
          "clip_id": "sub29",
          "text": "Porque lo bonito",
          "position": 42.32,
          "in": 0.0,
          "out": 0.5200000000000031,
          "filters": []
        },
        {
          "clip_id": "sub30",
          "text": "no es encontrar cosas\nen la calle.",
          "position": 42.84,
          "in": 0.0,
          "out": 1.8399999999999963,
          "filters": []
        },
        {
          "clip_id": "sub31",
          "text": "Lo bonito es que\nse compartan antes.",
          "position": 44.68,
          "in": 0.0,
          "out": 2.0799999999999983,
          "filters": []
        },
        {
          "clip_id": "sub32",
          "text": "Guardad esto",
          "position": 46.76,
          "in": 0.0,
          "out": 0.8400000000000034,
          "filters": []
        },
        {
          "clip_id": "sub33",
          "text": "y pas\u00e1dselo a alguien",
          "position": 47.6,
          "in": 0.0,
          "out": 1.2800000000000011,
          "filters": []
        },
        {
          "clip_id": "sub34",
          "text": "que necesite saberlo.",
          "position": 48.88,
          "in": 0.0,
          "out": 1.6799999999999997,
          "filters": []
        },
        {
          "clip_id": "sub35",
          "text": "As\u00ed es como crecemos.",
          "position": 50.56,
          "in": 0.0,
          "out": 1.3999999999999986,
          "filters": []
        }
