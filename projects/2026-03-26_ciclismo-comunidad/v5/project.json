        {
          "clip_id": "sub0",
          "text": "Cinco barrios.",
          "position": 0.0,
          "in": 0.0,
          "out": 0.92,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "Una bici.",
          "position": 0.92,
          "in": 0.0,
          "out": 0.84,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Y gente incre\u00edble\npor el camino.",
          "position": 1.76,
          "in": 0.0,
          "out": 1.72,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Despu\u00e9s del trabajo",
          "position": 3.48,
          "in": 0.0,
          "out": 0.8400000000000003,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "me pongo\na pedalear.",
          "position": 4.32,
          "in": 0.0,
          "out": 1.2399999999999993,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "Sin destino,\nsin prisa.",
          "position": 5.56,
          "in": 0.0,
          "out": 1.5200000000000005,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Solo las calles\ny yo.",
          "position": 7.08,
          "in": 0.0,
          "out": 1.0399999999999991,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Es mi manera\nde desconectar.",
          "position": 8.12,
          "in": 0.0,
          "out": 1.8000000000000007,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Y entre medias,",
          "position": 9.92,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "pillo cosas\nque la gente deja",
          "position": 10.92,
          "in": 0.0,
          "out": 1.5199999999999996,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "y a\u00fan valen.",
          "position": 12.44,
          "in": 0.0,
          "out": 1.040000000000001,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Las comparto",
          "position": 13.48,
          "in": 0.0,
          "out": 0.5599999999999987,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "y alguien les\nsaca partido.",
          "position": 14.04,
          "in": 0.0,
          "out": 1.6400000000000006,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "Y hay mucha gente\nhaciendo lo mismo.",
          "position": 15.68,
          "in": 0.0,
          "out": 1.4800000000000004,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "En bici,\na pie,",
          "position": 17.16,
          "in": 0.0,
          "out": 1.0799999999999983,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "como sea.",
          "position": 18.24,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "\u00bfVosotros ten\u00e9is\nun plan post-curro",
          "position": 19.24,
          "in": 0.0,
          "out": 1.4000000000000021,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "as\u00ed?",
