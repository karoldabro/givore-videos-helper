        },
        {
          "clip_id": "sub1",
          "text": "me subo\na la bici.",
          "position": 1.32,
          "in": 0.0,
          "out": 1.2,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Sin plan.",
          "position": 2.52,
          "in": 0.0,
          "out": 0.9199999999999999,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Solo yo,\nlas calles...",
          "position": 3.44,
          "in": 0.0,
          "out": 1.44,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "y el aire\nen la cara.",
          "position": 4.88,
          "in": 0.0,
          "out": 1.1600000000000001,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "Y es que mola.",
          "position": 6.04,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Mola mucho.",
          "position": 7.04,
          "in": 0.0,
          "out": 0.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Pedalear\npor tu ciudad,",
          "position": 7.88,
          "in": 0.0,
          "out": 1.12,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "ver el barrio,",
          "position": 9.0,
          "in": 0.0,
          "out": 0.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "desconectar\nde todo.",
          "position": 9.84,
          "in": 0.0,
          "out": 0.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "Para m\u00ed\nes lo mejor",
