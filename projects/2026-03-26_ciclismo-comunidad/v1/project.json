          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "que a\u00fan sirven",
          "position": 15.4,
          "in": 0.0,
          "out": 0.9199999999999999,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "y las comparto.",
          "position": 16.32,
          "in": 0.0,
          "out": 0.6799999999999997,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "Que alguien\nlas aproveche,",
          "position": 17.0,
          "in": 0.0,
          "out": 1.120000000000001,
