Dialogue: 0,00:00:00.63,00:00:01.100,Default,,0,0,0,,Sabeis cuanto tarda
Dialogue: 0,00:00:02.00,00:00:02.40,Default,,0,0,0,,la calle
Dialogue: 0,00:00:02.40,00:00:03.03,Default,,0,0,0,,en destrozar algo
Dialogue: 0,00:00:03.03,00:00:03.67,Default,,0,0,0,,que funcionaba
Dialogue: 0,00:00:03.67,00:00:04.43,Default,,0,0,0,,perfectamente?
Dialogue: 0,00:00:04.43,00:00:05.77,Default,,0,0,0,,Pasa esto.
Dialogue: 0,00:00:05.77,00:00:06.03,Default,,0,0,0,,El sol
Dialogue: 0,00:00:06.03,00:00:07.03,Default,,0,0,0,,lo decolora.
Dialogue: 0,00:00:07.03,00:00:07.63,Default,,0,0,0,,La lluvia
Dialogue: 0,00:00:07.63,00:00:07.97,Default,,0,0,0,,lo empapa
Dialogue: 0,00:00:07.97,00:00:08.80,Default,,0,0,0,,por dentro.
Dialogue: 0,00:00:08.80,00:00:09.87,Default,,0,0,0,,Y al final...
Dialogue: 0,00:00:09.87,00:00:10.30,Default,,0,0,0,,lo que era
Dialogue: 0,00:00:10.30,00:00:11.27,Default,,0,0,0,,un mueble util
Dialogue: 0,00:00:11.27,00:00:12.47,Default,,0,0,0,,acaba hecho polvo.
Dialogue: 0,00:00:12.47,00:00:13.40,Default,,0,0,0,,Se pierde.
Dialogue: 0,00:00:13.40,00:00:13.70,Default,,0,0,0,,Y es que
Dialogue: 0,00:00:13.70,00:00:14.57,Default,,0,0,0,,muchas veces...
Dialogue: 0,00:00:14.57,00:00:15.43,Default,,0,0,0,,bastaba con que
Dialogue: 0,00:00:15.43,00:00:15.83,Default,,0,0,0,,alguien lo viera
Dialogue: 0,00:00:15.83,00:00:16.70,Default,,0,0,0,,a tiempo.
Dialogue: 0,00:00:16.70,00:00:17.47,Default,,0,0,0,,Antes de que
Dialogue: 0,00:00:17.47,00:00:17.77,Default,,0,0,0,,el clima
Dialogue: 0,00:00:17.77,00:00:19.07,Default,,0,0,0,,hiciera su trabajo.
Dialogue: 0,00:00:19.07,00:00:19.97,Default,,0,0,0,,Una cosa menos
Dialogue: 0,00:00:19.97,00:00:20.37,Default,,0,0,0,,que se pierde.
Dialogue: 0,00:00:20.37,00:00:21.00,Default,,0,0,0,,Una cosa mas
Dialogue: 0,00:00:21.00,00:00:21.77,Default,,0,0,0,,que sigue viva.
Dialogue: 0,00:00:21.77,00:00:22.90,Default,,0,0,0,,Pues eso
Dialogue: 0,00:00:22.90,00:00:24.30,Default,,0,0,0,,tiene solucion.
Dialogue: 0,00:00:24.30,00:00:25.40,Default,,0,0,0,,Y es mas facil
Dialogue: 0,00:00:25.40,00:00:25.67,Default,,0,0,0,,de lo que
Dialogue: 0,00:00:25.67,00:00:26.63,Default,,0,0,0,,pensais.
Dialogue: 0,00:00:26.63,00:00:27.03,Default,,0,0,0,,Hoy en
Dialogue: 0,00:00:27.03,00:00:27.83,Default,,0,0,0,,La Petxina...
Dialogue: 0,00:00:27.83,00:00:28.57,Default,,0,0,0,,dos sillones.
Dialogue: 0,00:00:28.57,00:00:29.27,Default,,0,0,0,,Mirad.
Dialogue: 0,00:00:29.27,00:00:30.00,Default,,0,0,0,,Uno destrozado.
Dialogue: 0,00:00:30.00,00:00:30.70,Default,,0,0,0,,Tela rota,
Dialogue: 0,00:00:30.70,00:00:31.57,Default,,0,0,0,,estructura danada
Dialogue: 0,00:00:31.57,00:00:31.100,Default,,0,0,0,,por semanas
Dialogue: 0,00:00:32.00,00:00:32.100,Default,,0,0,0,,a la intemperie.
Dialogue: 0,00:00:33.00,00:00:34.00,Default,,0,0,0,,Y al lado...
Dialogue: 0,00:00:34.00,00:00:34.70,Default,,0,0,0,,otro.
Dialogue: 0,00:00:34.70,00:00:35.50,Default,,0,0,0,,Un poco sucio,
Dialogue: 0,00:00:35.50,00:00:35.77,Default,,0,0,0,,si.
Dialogue: 0,00:00:35.77,00:00:36.90,Default,,0,0,0,,Pero firme.
Dialogue: 0,00:00:36.90,00:00:37.60,Default,,0,0,0,,Entero.
Dialogue: 0,00:00:37.60,00:00:38.23,Default,,0,0,0,,Todavia tiene
Dialogue: 0,00:00:38.23,00:00:38.67,Default,,0,0,0,,mucho que dar.
Dialogue: 0,00:00:38.67,00:00:39.27,Default,,0,0,0,,Abro Givore.
Dialogue: 0,00:00:39.27,00:00:39.87,Default,,0,0,0,,Subo la foto,
Dialogue: 0,00:00:39.87,00:00:41.07,Default,,0,0,0,,pongo la ubicacion...
Dialogue: 0,00:00:41.07,00:00:41.43,Default,,0,0,0,,El bueno
Dialogue: 0,00:00:41.43,00:00:41.93,Default,,0,0,0,,va directo
Dialogue: 0,00:00:41.93,00:00:42.47,Default,,0,0,0,,a la app.
Dialogue: 0,00:00:42.47,00:00:43.43,Default,,0,0,0,,Guardad este video.
Dialogue: 0,00:00:43.43,00:00:44.37,Default,,0,0,0,,Para cuando veais
Dialogue: 0,00:00:44.37,00:00:45.00,Default,,0,0,0,,algo en la calle
Dialogue: 0,00:00:45.00,00:00:46.23,Default,,0,0,0,,que todavia sirve.
Dialogue: 0,00:00:46.23,00:00:46.97,Default,,0,0,0,,Y compartidlo
Dialogue: 0,00:00:46.97,00:00:47.37,Default,,0,0,0,,con alguien
Dialogue: 0,00:00:47.37,00:00:48.47,Default,,0,0,0,,de Valencia.
