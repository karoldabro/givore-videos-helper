Dialogue: 0,00:00:00.00,00:00:00.37,Default,,0,0,0,,¿Qué hace
Dialogue: 0,00:00:00.37,00:00:01.23,Default,,0,0,0,,una colchoneta nueva
Dialogue: 0,00:00:01.23,00:00:01.63,Default,,0,0,0,,tirada en
Dialogue: 0,00:00:01.63,00:00:02.60,Default,,0,0,0,,la acera?
Dialogue: 0,00:00:02.60,00:00:02.97,Default,,0,0,0,,Aquí,
Dialogue: 0,00:00:02.97,00:00:03.93,Default,,0,0,0,,en Alboraya.
Dialogue: 0,00:00:03.93,00:00:04.47,Default,,0,0,0,,Cerca de
Dialogue: 0,00:00:04.47,00:00:05.20,Default,,0,0,0,,la playa.
Dialogue: 0,00:00:05.20,00:00:06.27,Default,,0,0,0,,Y al lado...
Dialogue: 0,00:00:06.27,00:00:06.63,Default,,0,0,0,,una lámpara.
Dialogue: 0,00:00:06.63,00:00:07.67,Default,,0,0,0,,La lámpara necesita
Dialogue: 0,00:00:07.67,00:00:08.17,Default,,0,0,0,,un arreglo,
Dialogue: 0,00:00:08.17,00:00:08.73,Default,,0,0,0,,vale.
Dialogue: 0,00:00:08.73,00:00:09.67,Default,,0,0,0,,Pero la colchoneta
Dialogue: 0,00:00:09.67,00:00:10.87,Default,,0,0,0,,está impecable.
Dialogue: 0,00:00:10.87,00:00:12.17,Default,,0,0,0,,Sin un rasguño.
Dialogue: 0,00:00:12.17,00:00:12.63,Default,,0,0,0,,Y es que
Dialogue: 0,00:00:12.63,00:00:13.27,Default,,0,0,0,,esto no tendría
Dialogue: 0,00:00:13.27,00:00:13.80,Default,,0,0,0,,por qué acabar
Dialogue: 0,00:00:13.80,00:00:14.73,Default,,0,0,0,,en la calle.
Dialogue: 0,00:00:14.73,00:00:15.20,Default,,0,0,0,,Si alguien
Dialogue: 0,00:00:15.20,00:00:16.17,Default,,0,0,0,,la hubiera compartido
Dialogue: 0,00:00:16.17,00:00:17.17,Default,,0,0,0,,antes de sacarla...
Dialogue: 0,00:00:17.17,00:00:18.23,Default,,0,0,0,,habría llegado directa
Dialogue: 0,00:00:18.23,00:00:18.40,Default,,0,0,0,,a quien
Dialogue: 0,00:00:18.40,00:00:19.40,Default,,0,0,0,,la necesita.
Dialogue: 0,00:00:19.40,00:00:19.93,Default,,0,0,0,,Sin pasar
Dialogue: 0,00:00:19.93,00:00:20.83,Default,,0,0,0,,por la acera.
Dialogue: 0,00:00:20.83,00:00:21.93,Default,,0,0,0,,Sin mojarse.
Dialogue: 0,00:00:21.93,00:00:23.33,Default,,0,0,0,,Sin estropearse.
Dialogue: 0,00:00:23.33,00:00:23.97,Default,,0,0,0,,¿Sabéis qué
Dialogue: 0,00:00:23.97,00:00:24.27,Default,,0,0,0,,hago yo
Dialogue: 0,00:00:24.27,00:00:24.97,Default,,0,0,0,,cuando me encuentro
Dialogue: 0,00:00:24.97,00:00:25.63,Default,,0,0,0,,algo así?
Dialogue: 0,00:00:25.63,00:00:25.93,Default,,0,0,0,,Lo subo
Dialogue: 0,00:00:25.93,00:00:26.37,Default,,0,0,0,,a Givore.
Dialogue: 0,00:00:26.37,00:00:27.80,Default,,0,0,0,,Título, foto...
Dialogue: 0,00:00:27.80,00:00:28.57,Default,,0,0,0,,y listo.
Dialogue: 0,00:00:28.57,00:00:29.23,Default,,0,0,0,,Ya está visible
Dialogue: 0,00:00:29.23,00:00:30.53,Default,,0,0,0,,para cualquiera cerca.
Dialogue: 0,00:00:30.53,00:00:31.57,Default,,0,0,0,,Y fijaos...
Dialogue: 0,00:00:31.57,00:00:31.73,Default,,0,0,0,,a los
Dialogue: 0,00:00:31.73,00:00:32.37,Default,,0,0,0,,pocos minutos,
Dialogue: 0,00:00:32.37,00:00:32.67,Default,,0,0,0,,alguien de
Dialogue: 0,00:00:32.67,00:00:33.03,Default,,0,0,0,,la app
Dialogue: 0,00:00:33.03,00:00:33.60,Default,,0,0,0,,ya vino
Dialogue: 0,00:00:33.60,00:00:34.33,Default,,0,0,0,,a recogerla.
Dialogue: 0,00:00:34.33,00:00:35.23,Default,,0,0,0,,Minutos.
Dialogue: 0,00:00:35.23,00:00:36.27,Default,,0,0,0,,No horas.
Dialogue: 0,00:00:36.27,00:00:37.20,Default,,0,0,0,,Minutos.
Dialogue: 0,00:00:37.20,00:00:37.77,Default,,0,0,0,,Eso demuestra
Dialogue: 0,00:00:37.77,00:00:38.17,Default,,0,0,0,,que hay gente
Dialogue: 0,00:00:38.17,00:00:38.73,Default,,0,0,0,,que lo quiere.
Dialogue: 0,00:00:38.73,00:00:39.13,Default,,0,0,0,,Solo falta
Dialogue: 0,00:00:39.13,00:00:39.67,Default,,0,0,0,,que quien
Dialogue: 0,00:00:39.67,00:00:40.37,Default,,0,0,0,,lo tiene,
Dialogue: 0,00:00:40.37,00:00:41.03,Default,,0,0,0,,lo comparta
Dialogue: 0,00:00:41.03,00:00:41.87,Default,,0,0,0,,antes de dejarlo
Dialogue: 0,00:00:41.87,00:00:42.53,Default,,0,0,0,,en la calle.
Dialogue: 0,00:00:42.53,00:00:43.00,Default,,0,0,0,,Así todo
Dialogue: 0,00:00:43.00,00:00:44.07,Default,,0,0,0,,llega mejor.
Dialogue: 0,00:00:44.07,00:00:44.87,Default,,0,0,0,,Entero.
Dialogue: 0,00:00:44.87,00:00:45.27,Default,,0,0,0,,Limpio.
Dialogue: 0,00:00:45.27,00:00:46.33,Default,,0,0,0,,Cada paseo
Dialogue: 0,00:00:46.33,00:00:47.57,Default,,0,0,0,,aparece algo nuevo.
Dialogue: 0,00:00:47.57,00:00:48.60,Default,,0,0,0,,Si os mola...
Dialogue: 0,00:00:48.60,00:00:49.13,Default,,0,0,0,,seguidme.
Dialogue: 0,00:00:49.13,00:00:49.97,Default,,0,0,0,,Givore.
