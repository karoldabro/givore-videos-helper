Dialogue: 0,00:00:00.00,00:00:01.17,Default,,0,0,0,,De El Carmen
Dialogue: 0,00:00:01.17,00:00:01.80,Default,,0,0,0,,al Botanico...
Dialogue: 0,00:00:01.80,00:00:03.80,Default,,0,0,0,,pedaleando por Valencia.
Dialogue: 0,00:00:03.80,00:00:04.63,Default,,0,0,0,,Y lo que \Nme he encontrado
Dialogue: 0,00:00:04.63,00:00:06.23,Default,,0,0,0,,al final \Ndel recorrido...
Dialogue: 0,00:00:06.23,00:00:07.47,Default,,0,0,0,,lo teneis \Nque ver.
Dialogue: 0,00:00:07.47,00:00:08.37,Default,,0,0,0,,Esperad al final.
Dialogue: 0,00:00:08.37,00:00:10.23,Default,,0,0,0,,Pedaleo por \Nestos barrios
Dialogue: 0,00:00:10.23,00:00:11.67,Default,,0,0,0,,y cada dia \Nveo lo mismo.
Dialogue: 0,00:00:11.67,00:00:13.17,Default,,0,0,0,,Cosas en la calle.
Dialogue: 0,00:00:13.17,00:00:15.07,Default,,0,0,0,,Muebles, \Nobjetos...
Dialogue: 0,00:00:15.07,00:00:16.40,Default,,0,0,0,,que todavia \Ntienen vida.
Dialogue: 0,00:00:16.40,00:00:17.47,Default,,0,0,0,,Pero cuanto \Nmas tiempo
Dialogue: 0,00:00:17.47,00:00:18.57,Default,,0,0,0,,pasan aqui fuera,
Dialogue: 0,00:00:18.57,00:00:19.73,Default,,0,0,0,,mas se estropean.
Dialogue: 0,00:00:19.73,00:00:21.13,Default,,0,0,0,,La lluvia, \Nel sol...
Dialogue: 0,00:00:21.13,00:00:22.67,Default,,0,0,0,,todo les \Npasa factura.
Dialogue: 0,00:00:22.67,00:00:23.07,Default,,0,0,0,,Y es que
Dialogue: 0,00:00:23.07,00:00:24.83,Default,,0,0,0,,si se hubieran \Ncompartido a tiempo...
Dialogue: 0,00:00:24.83,00:00:25.57,Default,,0,0,0,,habrian llegado
Dialogue: 0,00:00:25.57,00:00:26.57,Default,,0,0,0,,a casa de alguien
Dialogue: 0,00:00:26.57,00:00:27.77,Default,,0,0,0,,en mucho \Nmejor estado.
Dialogue: 0,00:00:27.77,00:00:29.07,Default,,0,0,0,,Sin deteriorarse.
Dialogue: 0,00:00:29.07,00:00:30.03,Default,,0,0,0,,Sin esperar semanas
Dialogue: 0,00:00:30.03,00:00:31.13,Default,,0,0,0,,a que alguien \Npase y los vea.
Dialogue: 0,00:00:31.13,00:00:32.67,Default,,0,0,0,,Solo faltaba \Nla conexion.
Dialogue: 0,00:00:32.67,00:00:33.33,Default,,0,0,0,,Y esa conexion
Dialogue: 0,00:00:33.33,00:00:34.93,Default,,0,0,0,,la creamos \Nentre todos.
Dialogue: 0,00:00:34.93,00:00:35.53,Default,,0,0,0,,Yo lo que hago
Dialogue: 0,00:00:35.53,00:00:37.00,Default,,0,0,0,,es publicarlo \Nen Givore.
Dialogue: 0,00:00:37.00,00:00:38.33,Default,,0,0,0,,Foto, \Ntitulo,
Dialogue: 0,00:00:38.33,00:00:39.13,Default,,0,0,0,,y listo.
Dialogue: 0,00:00:39.13,00:00:41.03,Default,,0,0,0,,Visible para quien \Nlo necesite.
Dialogue: 0,00:00:41.03,00:00:41.80,Default,,0,0,0,,Y ahora si...
Dialogue: 0,00:00:41.80,00:00:42.53,Default,,0,0,0,,mirad.
Dialogue: 0,00:00:42.53,00:00:43.23,Default,,0,0,0,,Aun asi...
Dialogue: 0,00:00:43.23,00:00:44.13,Default,,0,0,0,,esperando a alguien
Dialogue: 0,00:00:44.13,00:00:44.77,Default,,0,0,0,,que le de
Dialogue: 0,00:00:44.77,00:00:45.77,Default,,0,0,0,,una segunda \Noportunidad.
Dialogue: 0,00:00:45.77,00:00:47.00,Default,,0,0,0,,Las dos van \Na Givore.
Dialogue: 0,00:00:47.00,00:00:47.57,Default,,0,0,0,,Alguien de \Npor aqui
Dialogue: 0,00:00:47.57,00:00:48.07,Default,,0,0,0,,les va a dar
Dialogue: 0,00:00:48.07,00:00:48.83,Default,,0,0,0,,esa segunda vida.
Dialogue: 0,00:00:48.83,00:00:50.27,Default,,0,0,0,,Tened Givore \Nen el movil.
Dialogue: 0,00:00:50.27,00:00:52.07,Default,,0,0,0,,Para encontrar \Ncosas asi.
Dialogue: 0,00:00:52.07,00:00:52.87,Default,,0,0,0,,Y para compartir
Dialogue: 0,00:00:52.87,00:00:54.20,Default,,0,0,0,,lo que ya \Nno usais...
Dialogue: 0,00:00:54.20,00:00:55.23,Default,,0,0,0,,antes de que acabe
Dialogue: 0,00:00:55.23,00:00:55.93,Default,,0,0,0,,aqui fuera.
