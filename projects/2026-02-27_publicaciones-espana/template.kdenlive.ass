Dialogue: 0,00:00:00.00,00:00:00.63,Default,,0,0,0,,Llevo semanas
Dialogue: 0,00:00:00.63,00:00:01.57,Default,,0,0,0,,viendo algo...
Dialogue: 0,00:00:01.57,00:00:02.37,Default,,0,0,0,,y cada día
Dialogue: 0,00:00:02.37,00:00:02.80,Default,,0,0,0,,va a más.
Dialogue: 0,00:00:02.80,00:00:03.07,Default,,0,0,0,,Gente por
Dialogue: 0,00:00:03.07,00:00:03.77,Default,,0,0,0,,toda España
Dialogue: 0,00:00:03.77,00:00:04.43,Default,,0,0,0,,publicando lo que
Dialogue: 0,00:00:04.43,00:00:05.33,Default,,0,0,0,,les sobra.
Dialogue: 0,00:00:05.33,00:00:05.97,Default,,0,0,0,,Sin pedir nada
Dialogue: 0,00:00:05.97,00:00:06.67,Default,,0,0,0,,a cambio.
Dialogue: 0,00:00:06.67,00:00:07.97,Default,,0,0,0,,Sin esperar nada.
Dialogue: 0,00:00:07.97,00:00:09.07,Default,,0,0,0,,Solo compartir.
Dialogue: 0,00:00:09.07,00:00:09.93,Default,,0,0,0,,Y al otro lado...
Dialogue: 0,00:00:09.93,00:00:11.00,Default,,0,0,0,,alguien lo descubre.
Dialogue: 0,00:00:11.00,00:00:11.87,Default,,0,0,0,,Mismo barrio.
Dialogue: 0,00:00:11.87,00:00:12.73,Default,,0,0,0,,Misma zona.
Dialogue: 0,00:00:12.73,00:00:13.23,Default,,0,0,0,,Sin haberse
Dialogue: 0,00:00:13.23,00:00:14.37,Default,,0,0,0,,cruzado nunca.
Dialogue: 0,00:00:14.37,00:00:15.07,Default,,0,0,0,,Y de repente...
Dialogue: 0,00:00:15.07,00:00:16.37,Default,,0,0,0,,conectan.
Dialogue: 0,00:00:16.37,00:00:16.60,Default,,0,0,0,,Eso es
Dialogue: 0,00:00:16.60,00:00:17.33,Default,,0,0,0,,lo que estamos
Dialogue: 0,00:00:17.33,00:00:18.03,Default,,0,0,0,,viendo.
Dialogue: 0,00:00:18.03,00:00:18.63,Default,,0,0,0,,No es una moda.
Dialogue: 0,00:00:18.63,00:00:19.33,Default,,0,0,0,,Es gente real
Dialogue: 0,00:00:19.33,00:00:20.00,Default,,0,0,0,,haciendo algo
Dialogue: 0,00:00:20.00,00:00:20.77,Default,,0,0,0,,que tiene sentido.
Dialogue: 0,00:00:20.77,00:00:22.03,Default,,0,0,0,,Personas que dan.
Dialogue: 0,00:00:22.03,00:00:23.40,Default,,0,0,0,,Personas que encuentran.
Dialogue: 0,00:00:23.40,00:00:25.00,Default,,0,0,0,,Sin complicaciones.
Dialogue: 0,00:00:25.00,00:00:25.97,Default,,0,0,0,,Y esto...
Dialogue: 0,00:00:25.97,00:00:26.93,Default,,0,0,0,,va creciendo.
Dialogue: 0,00:00:26.93,00:00:27.40,Default,,0,0,0,,Givore.
Dialogue: 0,00:00:27.40,00:00:28.20,Default,,0,0,0,,Si os sobra
Dialogue: 0,00:00:28.20,00:00:28.67,Default,,0,0,0,,algo en casa...
Dialogue: 0,00:00:28.67,00:00:29.53,Default,,0,0,0,,compartidlo.
Dialogue: 0,00:00:29.53,00:00:30.43,Default,,0,0,0,,Así de simple.
