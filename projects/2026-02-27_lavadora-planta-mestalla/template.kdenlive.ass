Dialogue: 0,00:00:00.00,00:00:01.13,Default,,0,0,0,,Esto me importa.
Dialogue: 0,00:00:01.13,00:00:01.87,Default,,0,0,0,,Mucho.
Dialogue: 0,00:00:01.87,00:00:02.63,Default,,0,0,0,,Hoy pedaleando
Dialogue: 0,00:00:02.63,00:00:03.43,Default,,0,0,0,,por Mestalla,
Dialogue: 0,00:00:03.43,00:00:04.77,Default,,0,0,0,,Albors, Amistad...
Dialogue: 0,00:00:04.77,00:00:05.77,Default,,0,0,0,,una lavadora.
Dialogue: 0,00:00:05.77,00:00:06.93,Default,,0,0,0,,En buen estado.
Dialogue: 0,00:00:06.93,00:00:07.83,Default,,0,0,0,,Sin daños visibles
Dialogue: 0,00:00:07.83,00:00:08.63,Default,,0,0,0,,por fuera.
Dialogue: 0,00:00:08.63,00:00:09.03,Default,,0,0,0,,Algo así
Dialogue: 0,00:00:09.03,00:00:09.77,Default,,0,0,0,,puede cambiarle
Dialogue: 0,00:00:09.77,00:00:10.57,Default,,0,0,0,,el mes a alguien
Dialogue: 0,00:00:10.57,00:00:11.77,Default,,0,0,0,,que la necesita.
Dialogue: 0,00:00:11.77,00:00:12.40,Default,,0,0,0,,Y es que
Dialogue: 0,00:00:12.40,00:00:13.57,Default,,0,0,0,,cada hallazgo
Dialogue: 0,00:00:13.57,00:00:14.33,Default,,0,0,0,,como este
Dialogue: 0,00:00:14.33,00:00:15.00,Default,,0,0,0,,es la prueba
Dialogue: 0,00:00:15.00,00:00:16.13,Default,,0,0,0,,de que funciona.
Dialogue: 0,00:00:16.13,00:00:16.67,Default,,0,0,0,,De que cuando
Dialogue: 0,00:00:16.67,00:00:17.60,Default,,0,0,0,,una comunidad
Dialogue: 0,00:00:17.60,00:00:19.33,Default,,0,0,0,,empieza a compartir...
Dialogue: 0,00:00:19.33,00:00:20.53,Default,,0,0,0,,pasan cosas bonitas.
Dialogue: 0,00:00:20.53,00:00:21.60,Default,,0,0,0,,En Valencia,
Dialogue: 0,00:00:21.60,00:00:22.77,Default,,0,0,0,,esto ya es real.
Dialogue: 0,00:00:22.77,00:00:24.17,Default,,0,0,0,,Vecinos que publican
Dialogue: 0,00:00:24.17,00:00:24.40,Default,,0,0,0,,lo que ya
Dialogue: 0,00:00:24.40,00:00:25.23,Default,,0,0,0,,no usan.
Dialogue: 0,00:00:25.23,00:00:26.07,Default,,0,0,0,,Gente que encuentra
Dialogue: 0,00:00:26.07,00:00:26.87,Default,,0,0,0,,lo que necesita.
Dialogue: 0,00:00:26.87,00:00:27.77,Default,,0,0,0,,Personas que
Dialogue: 0,00:00:27.77,00:00:28.53,Default,,0,0,0,,no se conocían,
Dialogue: 0,00:00:28.53,00:00:29.07,Default,,0,0,0,,conectando
Dialogue: 0,00:00:29.07,00:00:30.00,Default,,0,0,0,,por el barrio.
Dialogue: 0,00:00:30.00,00:00:30.73,Default,,0,0,0,,Y cada semana
Dialogue: 0,00:00:30.73,00:00:31.73,Default,,0,0,0,,se suman más.
Dialogue: 0,00:00:31.73,00:00:32.07,Default,,0,0,0,,¿Y sabéis
Dialogue: 0,00:00:32.07,00:00:33.03,Default,,0,0,0,,cómo empieza?
Dialogue: 0,00:00:33.03,00:00:34.07,Default,,0,0,0,,Con un gesto.
Dialogue: 0,00:00:34.07,00:00:34.97,Default,,0,0,0,,Uno solo.
Dialogue: 0,00:00:34.97,00:00:35.33,Default,,0,0,0,,Alguien que
Dialogue: 0,00:00:35.33,00:00:36.37,Default,,0,0,0,,comparte algo.
Dialogue: 0,00:00:36.37,00:00:36.73,Default,,0,0,0,,Alguien que
Dialogue: 0,00:00:36.73,00:00:37.47,Default,,0,0,0,,sale de casa
Dialogue: 0,00:00:37.47,00:00:38.13,Default,,0,0,0,,y descubre
Dialogue: 0,00:00:38.13,00:00:38.93,Default,,0,0,0,,un hallazgo.
Dialogue: 0,00:00:38.93,00:00:39.77,Default,,0,0,0,,Y de ahí...
Dialogue: 0,00:00:39.77,00:00:40.40,Default,,0,0,0,,nace algo
Dialogue: 0,00:00:40.40,00:00:41.13,Default,,0,0,0,,que ni os
Dialogue: 0,00:00:41.13,00:00:42.03,Default,,0,0,0,,imagináis.
Dialogue: 0,00:00:42.03,00:00:42.83,Default,,0,0,0,,Si en vuestra ciudad
Dialogue: 0,00:00:42.83,00:00:43.57,Default,,0,0,0,,todavía estáis
Dialogue: 0,00:00:43.57,00:00:44.00,Default,,0,0,0,,empezando...
Dialogue: 0,00:00:44.00,00:00:45.20,Default,,0,0,0,,paciencia.
Dialogue: 0,00:00:45.20,00:00:45.77,Default,,0,0,0,,Merece la pena
Dialogue: 0,00:00:45.77,00:00:46.60,Default,,0,0,0,,quedarse.
Dialogue: 0,00:00:46.60,00:00:47.40,Default,,0,0,0,,Porque cuando alguien
Dialogue: 0,00:00:47.40,00:00:48.27,Default,,0,0,0,,da el primer paso...
Dialogue: 0,00:00:48.27,00:00:49.67,Default,,0,0,0,,todo puede cambiar.
Dialogue: 0,00:00:49.67,00:00:50.57,Default,,0,0,0,,Esto lo construimos
Dialogue: 0,00:00:50.57,00:00:51.27,Default,,0,0,0,,entre todos.
Dialogue: 0,00:00:51.27,00:00:51.73,Default,,0,0,0,,Un gesto
Dialogue: 0,00:00:51.73,00:00:52.33,Default,,0,0,0,,a la vez.
