Dialogue: 0,00:00:00.00,00:00:01.37,Default,,0,0,0,,Regalar lo que \Nya no usáis
Dialogue: 0,00:00:01.37,00:00:02.80,Default,,0,0,0,,nunca ha sido \Ntan fácil.
Dialogue: 0,00:00:02.80,00:00:03.73,Default,,0,0,0,,Nos lo preguntáis \Nmucho.
Dialogue: 0,00:00:03.73,00:00:05.27,Default,,0,0,0,,Cómo se publica \Nun regalo
Dialogue: 0,00:00:05.27,00:00:05.63,Default,,0,0,0,,en Givore.
Dialogue: 0,00:00:05.63,00:00:06.37,Default,,0,0,0,,Pues venga,
Dialogue: 0,00:00:06.37,00:00:07.93,Default,,0,0,0,,hoy os lo enseño \Npaso a paso.
Dialogue: 0,00:00:07.93,00:00:08.80,Default,,0,0,0,,Abrís la app.
Dialogue: 0,00:00:08.80,00:00:09.93,Default,,0,0,0,,En la pantalla \Nprincipal,
Dialogue: 0,00:00:09.93,00:00:10.80,Default,,0,0,0,,abajo a la derecha,
Dialogue: 0,00:00:10.80,00:00:11.83,Default,,0,0,0,,tenéis un botón \Nverde
Dialogue: 0,00:00:11.83,00:00:13.20,Default,,0,0,0,,con el símbolo \Nmás.
Dialogue: 0,00:00:13.20,00:00:14.00,Default,,0,0,0,,Le dais.
Dialogue: 0,00:00:14.00,00:00:15.63,Default,,0,0,0,,Se abre \Nel formulario.
Dialogue: 0,00:00:15.63,00:00:17.23,Default,,0,0,0,,Lo primero, \Nel título.
Dialogue: 0,00:00:17.23,00:00:18.57,Default,,0,0,0,,Describid en \Npocas palabras
Dialogue: 0,00:00:18.57,00:00:19.87,Default,,0,0,0,,qué queréis \Nregalar.
Dialogue: 0,00:00:19.87,00:00:20.77,Default,,0,0,0,,Por ejemplo...
Dialogue: 0,00:00:20.77,00:00:21.63,Default,,0,0,0,,mesa de escritorio,
Dialogue: 0,00:00:21.63,00:00:22.83,Default,,0,0,0,,sillas de comedor...
Dialogue: 0,00:00:22.83,00:00:24.03,Default,,0,0,0,,Después, el tipo.
Dialogue: 0,00:00:24.03,00:00:25.07,Default,,0,0,0,,Seleccionáis \Nregalo.
Dialogue: 0,00:00:25.07,00:00:26.67,Default,,0,0,0,,La descripción \Nes opcional.
Dialogue: 0,00:00:26.67,00:00:28.63,Default,,0,0,0,,Pero si queréis \Nañadir detalles...
Dialogue: 0,00:00:28.63,00:00:29.53,Default,,0,0,0,,medidas, estado,
Dialogue: 0,00:00:29.53,00:00:30.13,Default,,0,0,0,,lo que sea...
Dialogue: 0,00:00:30.13,00:00:31.47,Default,,0,0,0,,este es el sitio.
Dialogue: 0,00:00:31.47,00:00:32.33,Default,,0,0,0,,Fotos.
Dialogue: 0,00:00:32.33,00:00:33.60,Default,,0,0,0,,Podéis añadir \Nhasta cinco.
Dialogue: 0,00:00:33.60,00:00:35.40,Default,,0,0,0,,Cuantas más \Npongáis, mejor.
Dialogue: 0,00:00:35.40,00:00:37.13,Default,,0,0,0,,Que se vea bien.
Dialogue: 0,00:00:37.13,00:00:37.93,Default,,0,0,0,,Y ahora...
Dialogue: 0,00:00:37.93,00:00:38.60,Default,,0,0,0,,ojo.
Dialogue: 0,00:00:38.60,00:00:39.77,Default,,0,0,0,,El tipo \Nde entrega.
Dialogue: 0,00:00:39.77,00:00:40.37,Default,,0,0,0,,Esto es clave.
Dialogue: 0,00:00:40.37,00:00:41.27,Default,,0,0,0,,Tenéis dos \Nopciones.
Dialogue: 0,00:00:41.27,00:00:42.27,Default,,0,0,0,,Mensaje...
Dialogue: 0,00:00:42.27,00:00:43.33,Default,,0,0,0,,o primero \Nen llegar.
Dialogue: 0,00:00:43.33,00:00:44.80,Default,,0,0,0,,Con mensaje,
Dialogue: 0,00:00:44.80,00:00:45.63,Default,,0,0,0,,la gente interesada
Dialogue: 0,00:00:45.63,00:00:46.63,Default,,0,0,0,,os escribe \Npor privado.
Dialogue: 0,00:00:46.63,00:00:48.60,Default,,0,0,0,,Chateáis y acordáis
Dialogue: 0,00:00:48.60,00:00:49.63,Default,,0,0,0,,cómo y cuándo.
Dialogue: 0,00:00:49.63,00:00:50.47,Default,,0,0,0,,Con primero \Nen llegar
Dialogue: 0,00:00:50.47,00:00:51.67,Default,,0,0,0,,no hay mensajes.
Dialogue: 0,00:00:51.67,00:00:53.40,Default,,0,0,0,,Vosotros escribís
Dialogue: 0,00:00:53.40,00:00:54.93,Default,,0,0,0,,instrucciones claras
Dialogue: 0,00:00:54.93,00:00:55.97,Default,,0,0,0,,y marcáis \Nla ubicación
Dialogue: 0,00:00:55.97,00:00:57.17,Default,,0,0,0,,con un pin \Nen el mapa.
Dialogue: 0,00:00:57.17,00:00:58.47,Default,,0,0,0,,Por ejemplo...
Dialogue: 0,00:00:58.47,00:00:59.53,Default,,0,0,0,,lo dejo este viernes
Dialogue: 0,00:00:59.53,00:01:00.33,Default,,0,0,0,,a las trece horas
Dialogue: 0,00:01:00.33,00:01:01.00,Default,,0,0,0,,en tal dirección.
Dialogue: 0,00:01:01.00,00:01:02.27,Default,,0,0,0,,Quien llegue \Nprimero,
Dialogue: 0,00:01:02.27,00:01:03.27,Default,,0,0,0,,se lo lleva.
Dialogue: 0,00:01:03.27,00:01:04.57,Default,,0,0,0,,Y en los \Ndos casos,
Dialogue: 0,00:01:04.57,00:01:06.13,Default,,0,0,0,,la gente puede \Ndejar comentarios
Dialogue: 0,00:01:06.13,00:01:07.03,Default,,0,0,0,,en vuestra \Npublicación.
Dialogue: 0,00:01:07.03,00:01:08.57,Default,,0,0,0,,Cuando lo tengáis \Ntodo,
Dialogue: 0,00:01:08.57,00:01:10.27,Default,,0,0,0,,le dais a guardar \Npublicación.
Dialogue: 0,00:01:10.27,00:01:11.77,Default,,0,0,0,,Se revisa \Ny se aprueba.
Dialogue: 0,00:01:11.77,00:01:12.40,Default,,0,0,0,,Y una cosa más.
Dialogue: 0,00:01:12.40,00:01:13.13,Default,,0,0,0,,Cuando el objeto
Dialogue: 0,00:01:13.13,00:01:14.27,Default,,0,0,0,,ya no esté \Ndisponible,
Dialogue: 0,00:01:14.27,00:01:15.53,Default,,0,0,0,,lo marcáis \Ncomo tal.
Dialogue: 0,00:01:15.53,00:01:16.40,Default,,0,0,0,,Y si os llegan
Dialogue: 0,00:01:16.40,00:01:17.57,Default,,0,0,0,,demasiados \Nmensajes
Dialogue: 0,00:01:17.57,00:01:18.67,Default,,0,0,0,,o lo tenéis \Nreservado...
Dialogue: 0,00:01:18.67,00:01:20.37,Default,,0,0,0,,podéis pausar \Nla publicación.
Dialogue: 0,00:01:20.37,00:01:21.37,Default,,0,0,0,,Así cortáis \Nlos mensajes
Dialogue: 0,00:01:21.37,00:01:22.03,Default,,0,0,0,,hasta que \Nqueráis.
Dialogue: 0,00:01:22.03,00:01:23.27,Default,,0,0,0,,Guardad este video.
Dialogue: 0,00:01:23.27,00:01:24.00,Default,,0,0,0,,Para la próxima vez
Dialogue: 0,00:01:24.00,00:01:24.80,Default,,0,0,0,,que queráis \Ndar algo.
Dialogue: 0,00:01:24.80,00:01:25.80,Default,,0,0,0,,Givore.
