Dialogue: 0,00:00:00.00,00:00:01.17,Default,,0,0,0,,¿Sabéis cuánto aguanta
Dialogue: 0,00:00:01.17,00:00:02.03,Default,,0,0,0,,un electrodoméstico
Dialogue: 0,00:00:02.03,00:00:02.93,Default,,0,0,0,,en la calle?
Dialogue: 0,00:00:02.93,00:00:03.60,Default,,0,0,0,,Menos de lo
Dialogue: 0,00:00:03.60,00:00:04.37,Default,,0,0,0,,que pensáis.
Dialogue: 0,00:00:04.37,00:00:05.17,Default,,0,0,0,,Esperad a ver
Dialogue: 0,00:00:05.17,00:00:05.47,Default,,0,0,0,,lo que me he
Dialogue: 0,00:00:05.47,00:00:06.23,Default,,0,0,0,,encontrado hoy
Dialogue: 0,00:00:06.23,00:00:07.20,Default,,0,0,0,,en Benimaclet.
Dialogue: 0,00:00:07.20,00:00:08.43,Default,,0,0,0,,Salgo con la bici...
Dialogue: 0,00:00:08.43,00:00:08.87,Default,,0,0,0,,y lo veo
Dialogue: 0,00:00:08.87,00:00:09.67,Default,,0,0,0,,a menudo.
Dialogue: 0,00:00:09.67,00:00:10.23,Default,,0,0,0,,Aparatos que
Dialogue: 0,00:00:10.23,00:00:11.53,Default,,0,0,0,,cuando los dejaron,
Dialogue: 0,00:00:11.53,00:00:12.37,Default,,0,0,0,,iban bien.
Dialogue: 0,00:00:12.37,00:00:13.37,Default,,0,0,0,,Pero pasan las horas,
Dialogue: 0,00:00:13.37,00:00:13.67,Default,,0,0,0,,llueve,
Dialogue: 0,00:00:13.67,00:00:14.60,Default,,0,0,0,,se golpean...
Dialogue: 0,00:00:14.60,00:00:15.87,Default,,0,0,0,,y cuando alguien
Dialogue: 0,00:00:15.87,00:00:16.07,Default,,0,0,0,,los ve,
Dialogue: 0,00:00:16.07,00:00:16.87,Default,,0,0,0,,ya no sirven.
Dialogue: 0,00:00:16.87,00:00:17.37,Default,,0,0,0,,Se pierden
Dialogue: 0,00:00:17.37,00:00:18.20,Default,,0,0,0,,por llegar tarde.
Dialogue: 0,00:00:18.20,00:00:18.73,Default,,0,0,0,,Y ahí está
Dialogue: 0,00:00:18.73,00:00:19.07,Default,,0,0,0,,la pena.
Dialogue: 0,00:00:19.07,00:00:19.93,Default,,0,0,0,,Que si se hubieran
Dialogue: 0,00:00:19.93,00:00:20.60,Default,,0,0,0,,compartido antes
Dialogue: 0,00:00:20.60,00:00:21.67,Default,,0,0,0,,de acabar ahí...
Dialogue: 0,00:00:21.67,00:00:22.33,Default,,0,0,0,,habrían llegado
Dialogue: 0,00:00:22.33,00:00:23.23,Default,,0,0,0,,perfectos.
Dialogue: 0,00:00:23.23,00:00:24.03,Default,,0,0,0,,A manos de alguien
Dialogue: 0,00:00:24.03,00:00:25.37,Default,,0,0,0,,que los necesita.
Dialogue: 0,00:00:25.37,00:00:26.27,Default,,0,0,0,,Os enseño.
Dialogue: 0,00:00:26.27,00:00:27.57,Default,,0,0,0,,Hoy me encontré dos.
Dialogue: 0,00:00:27.57,00:00:28.13,Default,,0,0,0,,Uno ya había
Dialogue: 0,00:00:28.13,00:00:28.97,Default,,0,0,0,,perdido la batalla.
Dialogue: 0,00:00:28.97,00:00:30.03,Default,,0,0,0,,Pero el otro
Dialogue: 0,00:00:30.03,00:00:30.97,Default,,0,0,0,,lo pillé a tiempo.
Dialogue: 0,00:00:30.97,00:00:32.03,Default,,0,0,0,,Lo subí a Givore.
Dialogue: 0,00:00:32.03,00:00:32.40,Default,,0,0,0,,Foto,
Dialogue: 0,00:00:32.40,00:00:32.97,Default,,0,0,0,,título,
Dialogue: 0,00:00:32.97,00:00:34.03,Default,,0,0,0,,publicar.
Dialogue: 0,00:00:34.03,00:00:34.73,Default,,0,0,0,,Visible para
Dialogue: 0,00:00:34.73,00:00:35.83,Default,,0,0,0,,todo el barrio.
Dialogue: 0,00:00:35.83,00:00:36.40,Default,,0,0,0,,Y en menos
Dialogue: 0,00:00:36.40,00:00:37.43,Default,,0,0,0,,de una hora...
Dialogue: 0,00:00:37.43,00:00:38.20,Default,,0,0,0,,un vecino vino
Dialogue: 0,00:00:38.20,00:00:38.83,Default,,0,0,0,,a recogerlo.
Dialogue: 0,00:00:38.83,00:00:40.20,Default,,0,0,0,,Funcionando.
Dialogue: 0,00:00:40.20,00:00:41.60,Default,,0,0,0,,Esa es la diferencia.
Dialogue: 0,00:00:41.60,00:00:42.27,Default,,0,0,0,,Lo que se comparte
Dialogue: 0,00:00:42.27,00:00:43.17,Default,,0,0,0,,a tiempo...
Dialogue: 0,00:00:43.17,00:00:44.03,Default,,0,0,0,,se salva.
Dialogue: 0,00:00:44.03,00:00:44.63,Default,,0,0,0,,Lo que se queda
Dialogue: 0,00:00:44.63,00:00:45.33,Default,,0,0,0,,en la calle...
Dialogue: 0,00:00:45.33,00:00:46.47,Default,,0,0,0,,se pierde.
Dialogue: 0,00:00:46.47,00:00:47.23,Default,,0,0,0,,En Givore,
Dialogue: 0,00:00:47.23,00:00:48.00,Default,,0,0,0,,la gente ofrece
Dialogue: 0,00:00:48.00,00:00:48.73,Default,,0,0,0,,lo que le sobra
Dialogue: 0,00:00:48.73,00:00:49.17,Default,,0,0,0,,antes de sacarlo
Dialogue: 0,00:00:49.17,00:00:50.17,Default,,0,0,0,,a la acera.
Dialogue: 0,00:00:50.17,00:00:51.17,Default,,0,0,0,,Y quien lo recibe,
Dialogue: 0,00:00:51.17,00:00:52.17,Default,,0,0,0,,lo recibe bien.
Dialogue: 0,00:00:52.17,00:00:52.53,Default,,0,0,0,,¿Habéis visto
Dialogue: 0,00:00:52.53,00:00:52.97,Default,,0,0,0,,algo así
Dialogue: 0,00:00:52.97,00:00:54.03,Default,,0,0,0,,en vuestro barrio?
Dialogue: 0,00:00:54.03,00:00:54.77,Default,,0,0,0,,¿Electrodomésticos
Dialogue: 0,00:00:54.77,00:00:55.57,Default,,0,0,0,,que ayer servían?
Dialogue: 0,00:00:55.57,00:00:56.63,Default,,0,0,0,,Contádmelo abajo.
Dialogue: 0,00:00:56.63,00:00:57.27,Default,,0,0,0,,Givore.
