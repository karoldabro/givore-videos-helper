Dialogue: 0,00:00:00.00,00:00:00.60,Default,,0,0,0,,No sabéis
Dialogue: 0,00:00:00.60,00:00:01.23,Default,,0,0,0,,cuántas cosas
Dialogue: 0,00:00:01.23,00:00:02.13,Default,,0,0,0,,me he encontrado
Dialogue: 0,00:00:02.13,00:00:02.67,Default,,0,0,0,,hoy pedaleando
Dialogue: 0,00:00:02.67,00:00:03.77,Default,,0,0,0,,por el Cabañal.
Dialogue: 0,00:00:03.77,00:00:05.13,Default,,0,0,0,,Sillas de oficina...
Dialogue: 0,00:00:05.13,00:00:05.80,Default,,0,0,0,,desmontadas,
Dialogue: 0,00:00:05.80,00:00:06.40,Default,,0,0,0,,pero buenas.
Dialogue: 0,00:00:06.40,00:00:07.07,Default,,0,0,0,,Con montarlas,
Dialogue: 0,00:00:07.07,00:00:07.87,Default,,0,0,0,,listas.
Dialogue: 0,00:00:07.87,00:00:08.83,Default,,0,0,0,,Y al lado...
Dialogue: 0,00:00:08.83,00:00:09.47,Default,,0,0,0,,una escalera
Dialogue: 0,00:00:09.47,00:00:10.17,Default,,0,0,0,,de madera.
Dialogue: 0,00:00:10.17,00:00:10.87,Default,,0,0,0,,Antigua.
Dialogue: 0,00:00:10.87,00:00:11.13,Default,,0,0,0,,De esas
Dialogue: 0,00:00:11.13,00:00:11.63,Default,,0,0,0,,del barrio
Dialogue: 0,00:00:11.63,00:00:12.17,Default,,0,0,0,,de pescadores,
Dialogue: 0,00:00:12.17,00:00:12.47,Default,,0,0,0,,de cuando
Dialogue: 0,00:00:12.47,00:00:13.03,Default,,0,0,0,,el Cabañal
Dialogue: 0,00:00:13.03,00:00:14.20,Default,,0,0,0,,era otra cosa.
Dialogue: 0,00:00:14.20,00:00:15.40,Default,,0,0,0,,Y esa escalera...
Dialogue: 0,00:00:15.40,00:00:16.43,Default,,0,0,0,,alguien creativo
Dialogue: 0,00:00:16.43,00:00:16.93,Default,,0,0,0,,le daría
Dialogue: 0,00:00:16.93,00:00:17.67,Default,,0,0,0,,una segunda vida
Dialogue: 0,00:00:17.67,00:00:18.37,Default,,0,0,0,,brutal.
Dialogue: 0,00:00:18.37,00:00:19.13,Default,,0,0,0,,Una estantería,
Dialogue: 0,00:00:19.13,00:00:19.87,Default,,0,0,0,,una decoración,
Dialogue: 0,00:00:19.87,00:00:20.37,Default,,0,0,0,,un proyecto.
Dialogue: 0,00:00:20.37,00:00:21.63,Default,,0,0,0,,Tiene esa madera
Dialogue: 0,00:00:21.63,00:00:21.87,Default,,0,0,0,,que ya no
Dialogue: 0,00:00:21.87,00:00:22.53,Default,,0,0,0,,se encuentra.
Dialogue: 0,00:00:22.53,00:00:23.53,Default,,0,0,0,,Pero esto
Dialogue: 0,00:00:23.53,00:00:24.33,Default,,0,0,0,,es lo que pasa.
Dialogue: 0,00:00:24.33,00:00:24.93,Default,,0,0,0,,Alguien deja
Dialogue: 0,00:00:24.93,00:00:25.63,Default,,0,0,0,,cosas así
Dialogue: 0,00:00:25.63,00:00:26.63,Default,,0,0,0,,en la acera...
Dialogue: 0,00:00:26.63,00:00:27.13,Default,,0,0,0,,y la persona
Dialogue: 0,00:00:27.13,00:00:27.63,Default,,0,0,0,,que las habría
Dialogue: 0,00:00:27.63,00:00:28.27,Default,,0,0,0,,querido,
Dialogue: 0,00:00:28.27,00:00:29.37,Default,,0,0,0,,ni se entera.
Dialogue: 0,00:00:29.37,00:00:30.93,Default,,0,0,0,,Falta ese puente.
Dialogue: 0,00:00:30.93,00:00:31.73,Default,,0,0,0,,Esa coneción
Dialogue: 0,00:00:31.73,00:00:32.33,Default,,0,0,0,,entre quien tiene
Dialogue: 0,00:00:32.33,00:00:32.73,Default,,0,0,0,,algo
Dialogue: 0,00:00:32.73,00:00:33.87,Default,,0,0,0,,y quien lo busca.
Dialogue: 0,00:00:33.87,00:00:34.57,Default,,0,0,0,,Lo que yo grabo
Dialogue: 0,00:00:34.57,00:00:35.27,Default,,0,0,0,,en estos vídeos
Dialogue: 0,00:00:35.27,00:00:36.27,Default,,0,0,0,,son solo ejemplos.
Dialogue: 0,00:00:36.27,00:00:37.07,Default,,0,0,0,,Cada día
Dialogue: 0,00:00:37.07,00:00:37.73,Default,,0,0,0,,pasa lo mismo
Dialogue: 0,00:00:37.73,00:00:38.27,Default,,0,0,0,,en cada barrio.
Dialogue: 0,00:00:38.27,00:00:39.60,Default,,0,0,0,,Cosas buenas
Dialogue: 0,00:00:39.60,00:00:40.47,Default,,0,0,0,,que se pierden
Dialogue: 0,00:00:40.47,00:00:41.20,Default,,0,0,0,,por no tener
Dialogue: 0,00:00:41.20,00:00:42.00,Default,,0,0,0,,una forma fácil
Dialogue: 0,00:00:42.00,00:00:42.77,Default,,0,0,0,,de compartirlas.
Dialogue: 0,00:00:42.77,00:00:43.33,Default,,0,0,0,,Por eso
Dialogue: 0,00:00:43.33,00:00:43.83,Default,,0,0,0,,siempre llevo
Dialogue: 0,00:00:43.83,00:00:44.73,Default,,0,0,0,,el móvil preparado.
Dialogue: 0,00:00:44.73,00:00:45.17,Default,,0,0,0,,Lo comparto
Dialogue: 0,00:00:45.17,00:00:45.63,Default,,0,0,0,,en Givore.
Dialogue: 0,00:00:45.63,00:00:46.23,Default,,0,0,0,,Título,
Dialogue: 0,00:00:46.23,00:00:46.60,Default,,0,0,0,,foto,
Dialogue: 0,00:00:46.60,00:00:47.37,Default,,0,0,0,,publico.
Dialogue: 0,00:00:47.37,00:00:48.47,Default,,0,0,0,,Y cualquiera cerca
Dialogue: 0,00:00:48.47,00:00:49.07,Default,,0,0,0,,lo puede ver
Dialogue: 0,00:00:49.07,00:00:49.33,Default,,0,0,0,,antes de que
Dialogue: 0,00:00:49.33,00:00:50.13,Default,,0,0,0,,desaparezca.
Dialogue: 0,00:00:50.13,00:00:51.23,Default,,0,0,0,,Por cierto...
Dialogue: 0,00:00:51.23,00:00:51.93,Default,,0,0,0,,gracias a los
Dialogue: 0,00:00:51.93,00:00:52.63,Default,,0,0,0,,que estáis usando
Dialogue: 0,00:00:52.63,00:00:53.00,Default,,0,0,0,,Givore
Dialogue: 0,00:00:53.00,00:00:53.97,Default,,0,0,0,,desde tantos sitios.
Dialogue: 0,00:00:53.97,00:00:54.83,Default,,0,0,0,,Valencia,
Dialogue: 0,00:00:54.83,00:00:55.23,Default,,0,0,0,,Madrid,
Dialogue: 0,00:00:55.23,00:00:56.00,Default,,0,0,0,,Barcelona,
Dialogue: 0,00:00:56.00,00:00:56.27,Default,,0,0,0,,Granada,
Dialogue: 0,00:00:56.27,00:00:56.93,Default,,0,0,0,,Zaragoza,
Dialogue: 0,00:00:56.93,00:00:57.80,Default,,0,0,0,,Alicante...
Dialogue: 0,00:00:57.80,00:00:58.53,Default,,0,0,0,,Esto funciona
Dialogue: 0,00:00:58.53,00:00:59.83,Default,,0,0,0,,porque participáis.
Dialogue: 0,00:00:59.83,00:01:00.47,Default,,0,0,0,,Y vosotros...
Dialogue: 0,00:01:00.47,00:01:01.27,Default,,0,0,0,,¿qué habéis
Dialogue: 0,00:01:01.27,00:01:01.77,Default,,0,0,0,,encontrado
Dialogue: 0,00:01:01.77,00:01:02.40,Default,,0,0,0,,en vuestro barrio?
Dialogue: 0,00:01:02.40,00:01:03.83,Default,,0,0,0,,Contádmelo.
Dialogue: 0,00:01:03.83,00:01:04.60,Default,,0,0,0,,Os leo.
