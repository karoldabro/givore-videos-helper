Dialogue: 0,00:00:00.00,00:00:00.60,Default,,0,0,0,,Cada vez que
Dialogue: 0,00:00:00.60,00:00:01.40,Default,,0,0,0,,cojo la bici...
Dialogue: 0,00:00:01.40,00:00:02.20,Default,,0,0,0,,acabo encontrando
Dialogue: 0,00:00:02.20,00:00:02.80,Default,,0,0,0,,algo.
Dialogue: 0,00:00:02.80,00:00:03.13,Default,,0,0,0,,Y lo que
Dialogue: 0,00:00:03.13,00:00:03.97,Default,,0,0,0,,mas os va
Dialogue: 0,00:00:03.97,00:00:04.60,Default,,0,0,0,,a sorprender
Dialogue: 0,00:00:04.60,00:00:04.93,Default,,0,0,0,,no es lo
Dialogue: 0,00:00:04.93,00:00:05.80,Default,,0,0,0,,que encuentro.
Dialogue: 0,00:00:05.80,00:00:06.23,Default,,0,0,0,,Es lo que
Dialogue: 0,00:00:06.23,00:00:07.17,Default,,0,0,0,,le pasa despues.
Dialogue: 0,00:00:07.17,00:00:07.40,Default,,0,0,0,,Hoy,
Dialogue: 0,00:00:07.40,00:00:08.47,Default,,0,0,0,,en el Cabanal...
Dialogue: 0,00:00:08.47,00:00:09.47,Default,,0,0,0,,una impresora.
Dialogue: 0,00:00:09.47,00:00:10.17,Default,,0,0,0,,Y al lado,
Dialogue: 0,00:00:10.17,00:00:11.40,Default,,0,0,0,,una mesa antigua.
Dialogue: 0,00:00:11.40,00:00:12.60,Default,,0,0,0,,La impresora
Dialogue: 0,00:00:12.60,00:00:13.27,Default,,0,0,0,,igual no arranca.
Dialogue: 0,00:00:13.27,00:00:14.53,Default,,0,0,0,,Pero hay gente
Dialogue: 0,00:00:14.53,00:00:15.03,Default,,0,0,0,,que la quiere
Dialogue: 0,00:00:15.03,00:00:16.23,Default,,0,0,0,,incluso para piezas.
Dialogue: 0,00:00:16.23,00:00:17.13,Default,,0,0,0,,Y la mesa,
Dialogue: 0,00:00:17.13,00:00:17.73,Default,,0,0,0,,con un lijado
Dialogue: 0,00:00:17.73,00:00:18.00,Default,,0,0,0,,y algo
Dialogue: 0,00:00:18.00,00:00:18.43,Default,,0,0,0,,de trabajo,
Dialogue: 0,00:00:18.43,00:00:19.47,Default,,0,0,0,,queda de diez.
Dialogue: 0,00:00:19.47,00:00:19.77,Default,,0,0,0,,Ahora,
Dialogue: 0,00:00:19.77,00:00:20.37,Default,,0,0,0,,el dato.
Dialogue: 0,00:00:20.37,00:00:20.87,Default,,0,0,0,,Cuando algo
Dialogue: 0,00:00:20.87,00:00:21.47,Default,,0,0,0,,se queda
Dialogue: 0,00:00:21.47,00:00:22.20,Default,,0,0,0,,en la calle...
Dialogue: 0,00:00:22.20,00:00:23.03,Default,,0,0,0,,no espera.
Dialogue: 0,00:00:23.03,00:00:23.87,Default,,0,0,0,,Se degrada.
Dialogue: 0,00:00:23.87,00:00:24.40,Default,,0,0,0,,En horas.
Dialogue: 0,00:00:24.40,00:00:24.77,Default,,0,0,0,,El sol
Dialogue: 0,00:00:24.77,00:00:25.17,Default,,0,0,0,,lo reseca,
Dialogue: 0,00:00:25.17,00:00:25.67,Default,,0,0,0,,la lluvia
Dialogue: 0,00:00:25.67,00:00:26.17,Default,,0,0,0,,lo empapa,
Dialogue: 0,00:00:26.17,00:00:27.13,Default,,0,0,0,,alguien pasa
Dialogue: 0,00:00:27.13,00:00:27.80,Default,,0,0,0,,y le saca
Dialogue: 0,00:00:27.80,00:00:28.23,Default,,0,0,0,,lo que puede
Dialogue: 0,00:00:28.23,00:00:28.67,Default,,0,0,0,,revender...
Dialogue: 0,00:00:28.67,00:00:28.97,Default,,0,0,0,,y lo que
Dialogue: 0,00:00:28.97,00:00:29.27,Default,,0,0,0,,queda
Dialogue: 0,00:00:29.27,00:00:30.00,Default,,0,0,0,,ya no le sirve
Dialogue: 0,00:00:30.00,00:00:30.73,Default,,0,0,0,,a nadie.
Dialogue: 0,00:00:30.73,00:00:30.97,Default,,0,0,0,,Pero si
Dialogue: 0,00:00:30.97,00:00:31.47,Default,,0,0,0,,eso mismo
Dialogue: 0,00:00:31.47,00:00:31.97,Default,,0,0,0,,se comparte
Dialogue: 0,00:00:31.97,00:00:32.53,Default,,0,0,0,,antes de acabar
Dialogue: 0,00:00:32.53,00:00:33.43,Default,,0,0,0,,en la acera...
Dialogue: 0,00:00:33.43,00:00:34.17,Default,,0,0,0,,llega bien.
Dialogue: 0,00:00:34.17,00:00:34.60,Default,,0,0,0,,Llega entero.
Dialogue: 0,00:00:34.60,00:00:35.33,Default,,0,0,0,,Y llega
Dialogue: 0,00:00:35.33,00:00:35.97,Default,,0,0,0,,a alguien
Dialogue: 0,00:00:35.97,00:00:36.37,Default,,0,0,0,,que lo va
Dialogue: 0,00:00:36.37,00:00:36.63,Default,,0,0,0,,a usar
Dialogue: 0,00:00:36.63,00:00:37.43,Default,,0,0,0,,de verdad.
Dialogue: 0,00:00:37.43,00:00:38.03,Default,,0,0,0,,Mirad.
Dialogue: 0,00:00:38.03,00:00:38.53,Default,,0,0,0,,En Givore,
Dialogue: 0,00:00:38.53,00:00:39.27,Default,,0,0,0,,subo las fotos,
Dialogue: 0,00:00:39.27,00:00:40.53,Default,,0,0,0,,pongo la ubicacion...
Dialogue: 0,00:00:40.53,00:00:40.93,Default,,0,0,0,,y ya estan
Dialogue: 0,00:00:40.93,00:00:41.27,Default,,0,0,0,,visibles
Dialogue: 0,00:00:41.27,00:00:42.60,Default,,0,0,0,,para cualquiera cerca.
Dialogue: 0,00:00:42.60,00:00:43.23,Default,,0,0,0,,Esa impresora
Dialogue: 0,00:00:43.23,00:00:43.80,Default,,0,0,0,,y esa mesa
Dialogue: 0,00:00:43.80,00:00:44.57,Default,,0,0,0,,llevan publicadas
Dialogue: 0,00:00:44.57,00:00:45.23,Default,,0,0,0,,diez minutos.
Dialogue: 0,00:00:45.23,00:00:46.40,Default,,0,0,0,,Alguien del barrio
Dialogue: 0,00:00:46.40,00:00:46.93,Default,,0,0,0,,las puede recoger
Dialogue: 0,00:00:46.93,00:00:47.20,Default,,0,0,0,,hoy.
Dialogue: 0,00:00:47.20,00:00:48.27,Default,,0,0,0,,Cuando la probeis,
Dialogue: 0,00:00:48.27,00:00:48.67,Default,,0,0,0,,vais a ver
Dialogue: 0,00:00:48.67,00:00:49.17,Default,,0,0,0,,la calle
Dialogue: 0,00:00:49.17,00:00:50.03,Default,,0,0,0,,de otra forma.
Dialogue: 0,00:00:50.03,00:00:50.67,Default,,0,0,0,,Givore.
