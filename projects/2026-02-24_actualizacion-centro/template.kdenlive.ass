Dialogue: 0,00:00:00.00,00:00:01.80,Default,,0,0,0,,Cada dia \Nse tiran \Nen Espana
Dialogue: 0,00:00:01.80,00:00:04.17,Default,,0,0,0,,miles de cosas \Nque funcionan \Nperfectamente.
Dialogue: 0,00:00:04.17,00:00:06.23,Default,,0,0,0,,Muebles, \Nelectrodomesticos, \Njuguetes...
Dialogue: 0,00:00:06.23,00:00:07.57,Default,,0,0,0,,directos \Na la basura.
Dialogue: 0,00:00:07.57,00:00:09.57,Default,,0,0,0,,Pero hay gente \Nque esta \Ncambiando eso.
Dialogue: 0,00:00:09.57,00:00:11.67,Default,,0,0,0,,Vecinos que comparten \Nlo que ya \Nno usan.
Dialogue: 0,00:00:11.67,00:00:13.80,Default,,0,0,0,,Gente que \Nse ahorra \Ncientos de euros \Nal mes.
Dialogue: 0,00:00:13.80,00:00:16.87,Default,,0,0,0,,Cosas rescatadas \Nque acaban \Nen casas nuevas
Dialogue: 0,00:00:16.87,00:00:18.77,Default,,0,0,0,,en vez de \Nen un vertedero.
Dialogue: 0,00:00:18.77,00:00:20.03,Default,,0,0,0,,Y cada semana \Nse suman mas.
Dialogue: 0,00:00:20.03,00:00:21.07,Default,,0,0,0,,Esto es Givore.
Dialogue: 0,00:00:21.07,00:00:22.73,Default,,0,0,0,,Tu compartes \Nlo que te sobra.
Dialogue: 0,00:00:22.73,00:00:24.07,Default,,0,0,0,,Otro lo encuentra.
Dialogue: 0,00:00:24.07,00:00:24.73,Default,,0,0,0,,Sin pagar.
Dialogue: 0,00:00:24.73,00:00:25.80,Default,,0,0,0,,Sin intermediarios.
Dialogue: 0,00:00:25.80,00:00:27.67,Default,,0,0,0,,Menos residuos, \Nmas comunidad.
Dialogue: 0,00:00:27.67,00:00:29.77,Default,,0,0,0,,Y acaba de salir \Nla version \Nuno punto tres.
Dialogue: 0,00:00:29.77,00:00:30.83,Default,,0,0,0,,Mas rapida, \Nmas limpia,
Dialogue: 0,00:00:30.83,00:00:31.67,Default,,0,0,0,,funciones nuevas.
Dialogue: 0,00:00:31.67,00:00:32.57,Default,,0,0,0,,Otro nivel.
Dialogue: 0,00:00:32.57,00:00:34.23,Default,,0,0,0,,Gracias a los que \Nestais participando.
Dialogue: 0,00:00:34.23,00:00:35.77,Default,,0,0,0,,Esto crece \Npor vosotros.
Dialogue: 0,00:00:35.77,00:00:37.37,Default,,0,0,0,,Y ahora... \Nla noticia.
Dialogue: 0,00:00:37.37,00:00:39.20,Default,,0,0,0,,Estamos preparando \NGivore para iOS.
Dialogue: 0,00:00:39.20,00:00:40.00,Default,,0,0,0,,Los de iPhone...
Dialogue: 0,00:00:40.00,00:00:41.87,Default,,0,0,0,,pronto vais \Na poder usarla.
Dialogue: 0,00:00:41.87,00:00:44.00,Default,,0,0,0,,Dejad un comentario \Ncon la palabra iOS
Dialogue: 0,00:00:44.00,00:00:46.23,Default,,0,0,0,,si quereis \Nque os avise \Ncuando este lista.
Dialogue: 0,00:00:46.23,00:00:47.03,Default,,0,0,0,,Solo eso.
Dialogue: 0,00:00:47.03,00:00:48.07,Default,,0,0,0,,Y sois \Nlos primeros.
Dialogue: 0,00:00:48.07,00:00:49.20,Default,,0,0,0,,Nos vemos \Nen las calles.
