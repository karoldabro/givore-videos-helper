Dialogue: 0,00:00:00.00,00:00:00.93,Default,,0,0,0,,Una mesa entera
Dialogue: 0,00:00:00.93,00:00:01.47,Default,,0,0,0,,ahi,
Dialogue: 0,00:00:01.47,00:00:02.77,Default,,0,0,0,,junto al contenedor.
Dialogue: 0,00:00:02.77,00:00:03.57,Default,,0,0,0,,En el Cabañal.
Dialogue: 0,00:00:03.57,00:00:04.73,Default,,0,0,0,,Cuatro muebles.
Dialogue: 0,00:00:04.73,00:00:05.57,Default,,0,0,0,,Una mesa,
Dialogue: 0,00:00:05.57,00:00:06.40,Default,,0,0,0,,un somier,
Dialogue: 0,00:00:06.40,00:00:07.07,Default,,0,0,0,,un perchero
Dialogue: 0,00:00:07.07,00:00:07.77,Default,,0,0,0,,y una mesita
Dialogue: 0,00:00:07.77,00:00:08.57,Default,,0,0,0,,de noche.
Dialogue: 0,00:00:08.57,00:00:08.83,Default,,0,0,0,,Todo en
Dialogue: 0,00:00:08.83,00:00:09.43,Default,,0,0,0,,buen estado.
Dialogue: 0,00:00:09.43,00:00:10.60,Default,,0,0,0,,Todo esperando
Dialogue: 0,00:00:10.60,00:00:11.07,Default,,0,0,0,,a que pase
Dialogue: 0,00:00:11.07,00:00:11.67,Default,,0,0,0,,el camion.
Dialogue: 0,00:00:11.67,00:00:12.47,Default,,0,0,0,,Y esto es
Dialogue: 0,00:00:12.47,00:00:13.07,Default,,0,0,0,,lo que mola
Dialogue: 0,00:00:13.07,00:00:13.57,Default,,0,0,0,,del Cabañal.
Dialogue: 0,00:00:13.57,00:00:14.87,Default,,0,0,0,,Caminas dos calles
Dialogue: 0,00:00:14.87,00:00:15.60,Default,,0,0,0,,y te encuentras
Dialogue: 0,00:00:15.60,00:00:15.87,Default,,0,0,0,,de todo.
Dialogue: 0,00:00:15.87,00:00:17.00,Default,,0,0,0,,Cosas que alguien
Dialogue: 0,00:00:17.00,00:00:17.60,Default,,0,0,0,,dejo hace
Dialogue: 0,00:00:17.60,00:00:18.53,Default,,0,0,0,,unas horas...
Dialogue: 0,00:00:18.53,00:00:19.57,Default,,0,0,0,,que todavia sirven.
Dialogue: 0,00:00:19.57,00:00:21.03,Default,,0,0,0,,Que todavia valen.
Dialogue: 0,00:00:21.03,00:00:21.83,Default,,0,0,0,,Pero aqui va
Dialogue: 0,00:00:21.83,00:00:22.57,Default,,0,0,0,,el dato.
Dialogue: 0,00:00:22.57,00:00:23.47,Default,,0,0,0,,Cada semana,
Dialogue: 0,00:00:23.47,00:00:24.53,Default,,0,0,0,,muebles como estos
Dialogue: 0,00:00:24.53,00:00:25.17,Default,,0,0,0,,acaban en
Dialogue: 0,00:00:25.17,00:00:26.13,Default,,0,0,0,,un vertedero.
Dialogue: 0,00:00:26.13,00:00:26.97,Default,,0,0,0,,Muebles que podrian
Dialogue: 0,00:00:26.97,00:00:27.33,Default,,0,0,0,,estar en
Dialogue: 0,00:00:27.33,00:00:28.23,Default,,0,0,0,,otro salon,
Dialogue: 0,00:00:28.23,00:00:29.47,Default,,0,0,0,,en otra habitacion.
Dialogue: 0,00:00:29.47,00:00:30.20,Default,,0,0,0,,Con anos de vida
Dialogue: 0,00:00:30.20,00:00:30.67,Default,,0,0,0,,por delante.
Dialogue: 0,00:00:30.67,00:00:31.17,Default,,0,0,0,,Pues eso
Dialogue: 0,00:00:31.17,00:00:31.87,Default,,0,0,0,,tiene solucion.
Dialogue: 0,00:00:31.87,00:00:32.93,Default,,0,0,0,,Y es muy facil.
Dialogue: 0,00:00:32.93,00:00:33.47,Default,,0,0,0,,En Givore,
Dialogue: 0,00:00:33.47,00:00:34.13,Default,,0,0,0,,lo compartes
Dialogue: 0,00:00:34.13,00:00:34.57,Default,,0,0,0,,antes de que
Dialogue: 0,00:00:34.57,00:00:35.03,Default,,0,0,0,,acabe asi.
Dialogue: 0,00:00:35.03,00:00:35.37,Default,,0,0,0,,Foto,
Dialogue: 0,00:00:35.37,00:00:35.73,Default,,0,0,0,,titulo,
Dialogue: 0,00:00:35.73,00:00:36.63,Default,,0,0,0,,publicar.
Dialogue: 0,00:00:36.63,00:00:37.33,Default,,0,0,0,,Ya esta visible
Dialogue: 0,00:00:37.33,00:00:37.67,Default,,0,0,0,,para quien
Dialogue: 0,00:00:37.67,00:00:38.40,Default,,0,0,0,,lo busque.
Dialogue: 0,00:00:38.40,00:00:39.07,Default,,0,0,0,,Y llega entero,
Dialogue: 0,00:00:39.07,00:00:39.63,Default,,0,0,0,,sin pasar
Dialogue: 0,00:00:39.63,00:00:40.57,Default,,0,0,0,,por la calle.
Dialogue: 0,00:00:40.57,00:00:41.03,Default,,0,0,0,,El perchero
Dialogue: 0,00:00:41.03,00:00:41.40,Default,,0,0,0,,y la mesita
Dialogue: 0,00:00:41.40,00:00:42.33,Default,,0,0,0,,los subi.
Dialogue: 0,00:00:42.33,00:00:42.80,Default,,0,0,0,,Ahora mismo
Dialogue: 0,00:00:42.80,00:00:43.40,Default,,0,0,0,,alguien del barrio
Dialogue: 0,00:00:43.40,00:00:44.07,Default,,0,0,0,,puede verlos.
Dialogue: 0,00:00:44.07,00:00:44.80,Default,,0,0,0,,Asi de rapido.
Dialogue: 0,00:00:44.80,00:00:45.63,Default,,0,0,0,,Guardad esto
Dialogue: 0,00:00:45.63,00:00:46.53,Default,,0,0,0,,para cuando veais
Dialogue: 0,00:00:46.53,00:00:47.53,Default,,0,0,0,,algo en la calle.
Dialogue: 0,00:00:47.53,00:00:47.97,Default,,0,0,0,,O enviadlo
Dialogue: 0,00:00:47.97,00:00:48.33,Default,,0,0,0,,a alguien
Dialogue: 0,00:00:48.33,00:00:48.77,Default,,0,0,0,,que viva
Dialogue: 0,00:00:48.77,00:00:49.37,Default,,0,0,0,,en Valencia.
Dialogue: 0,00:00:49.37,00:00:50.40,Default,,0,0,0,,Givore.
