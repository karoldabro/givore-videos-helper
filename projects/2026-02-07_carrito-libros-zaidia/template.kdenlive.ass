Dialogue: 0,00:00:00.00,00:00:00.63,Default,,0,0,0,,Hoy he salido
Dialogue: 0,00:00:00.63,00:00:01.13,Default,,0,0,0,,con la bici
Dialogue: 0,00:00:01.13,00:00:01.60,Default,,0,0,0,,sin saber
Dialogue: 0,00:00:01.60,00:00:02.40,Default,,0,0,0,,lo que me esperaba.
Dialogue: 0,00:00:02.40,00:00:03.53,Default,,0,0,0,,Empecé tranquilo...
Dialogue: 0,00:00:03.53,00:00:03.97,Default,,0,0,0,,y al final
Dialogue: 0,00:00:03.97,00:00:04.83,Default,,0,0,0,,todo cambió.
Dialogue: 0,00:00:04.83,00:00:05.53,Default,,0,0,0,,Esperad a ver
Dialogue: 0,00:00:05.53,00:00:06.13,Default,,0,0,0,,lo que pasó.
Dialogue: 0,00:00:06.13,00:00:06.57,Default,,0,0,0,,Salgo por
Dialogue: 0,00:00:06.57,00:00:07.37,Default,,0,0,0,,La Zaidía.
Dialogue: 0,00:00:07.37,00:00:07.63,Default,,0,0,0,,Sol.
Dialogue: 0,00:00:07.63,00:00:08.63,Default,,0,0,0,,Tranquilidad.
Dialogue: 0,00:00:08.63,00:00:09.40,Default,,0,0,0,,Y de repente...
Dialogue: 0,00:00:09.40,00:00:10.57,Default,,0,0,0,,cosas en la acera.
Dialogue: 0,00:00:10.57,00:00:11.03,Default,,0,0,0,,Un carrito
Dialogue: 0,00:00:11.03,00:00:11.93,Default,,0,0,0,,de la compra.
Dialogue: 0,00:00:11.93,00:00:13.00,Default,,0,0,0,,Libros apilados.
Dialogue: 0,00:00:13.00,00:00:13.87,Default,,0,0,0,,Una nevera...
Dialogue: 0,00:00:13.87,00:00:15.03,Default,,0,0,0,,destrozada.
Dialogue: 0,00:00:15.03,00:00:16.03,Default,,0,0,0,,Alguien la dejó
Dialogue: 0,00:00:16.03,00:00:16.37,Default,,0,0,0,,y alguien
Dialogue: 0,00:00:16.37,00:00:17.33,Default,,0,0,0,,la reventó.
Dialogue: 0,00:00:17.33,00:00:18.00,Default,,0,0,0,,El carrito
Dialogue: 0,00:00:18.00,00:00:18.43,Default,,0,0,0,,y los libros
Dialogue: 0,00:00:18.43,00:00:19.47,Default,,0,0,0,,estaban bien.
Dialogue: 0,00:00:19.47,00:00:20.43,Default,,0,0,0,,Pero entonces...
Dialogue: 0,00:00:20.43,00:00:21.80,Default,,0,0,0,,empezó a llover.
Dialogue: 0,00:00:21.80,00:00:22.03,Default,,0,0,0,,Y ahí
Dialogue: 0,00:00:22.03,00:00:22.73,Default,,0,0,0,,cambia todo.
Dialogue: 0,00:00:22.73,00:00:23.23,Default,,0,0,0,,Porque lo que
Dialogue: 0,00:00:23.23,00:00:23.67,Default,,0,0,0,,ahora mismo
Dialogue: 0,00:00:23.67,00:00:24.60,Default,,0,0,0,,está bien...
Dialogue: 0,00:00:24.60,00:00:25.47,Default,,0,0,0,,en unas horas
Dialogue: 0,00:00:25.47,00:00:26.13,Default,,0,0,0,,se empapa.
Dialogue: 0,00:00:26.13,00:00:27.07,Default,,0,0,0,,Se hincha.
Dialogue: 0,00:00:27.07,00:00:28.00,Default,,0,0,0,,Se pierde.
Dialogue: 0,00:00:28.00,00:00:28.53,Default,,0,0,0,,Es cuestión
Dialogue: 0,00:00:28.53,00:00:29.37,Default,,0,0,0,,de tiempo.
Dialogue: 0,00:00:29.37,00:00:29.87,Default,,0,0,0,,Y eso es
Dialogue: 0,00:00:29.87,00:00:30.20,Default,,0,0,0,,lo que pasa
Dialogue: 0,00:00:30.20,00:00:31.00,Default,,0,0,0,,cuando las cosas
Dialogue: 0,00:00:31.00,00:00:31.63,Default,,0,0,0,,se dejan
Dialogue: 0,00:00:31.63,00:00:31.93,Default,,0,0,0,,en la calle.
Dialogue: 0,00:00:31.93,00:00:32.63,Default,,0,0,0,,Que dependen
Dialogue: 0,00:00:32.63,00:00:33.83,Default,,0,0,0,,de la suerte.
Dialogue: 0,00:00:33.83,00:00:34.43,Default,,0,0,0,,Del tiempo.
Dialogue: 0,00:00:34.43,00:00:35.33,Default,,0,0,0,,De que alguien
Dialogue: 0,00:00:35.33,00:00:36.13,Default,,0,0,0,,pase justo
Dialogue: 0,00:00:36.13,00:00:36.60,Default,,0,0,0,,en el momento
Dialogue: 0,00:00:36.60,00:00:37.07,Default,,0,0,0,,adecuado.
Dialogue: 0,00:00:37.07,00:00:37.97,Default,,0,0,0,,Pero hay
Dialogue: 0,00:00:37.97,00:00:38.53,Default,,0,0,0,,otra manera.
Dialogue: 0,00:00:38.53,00:00:39.20,Default,,0,0,0,,En Givore,
Dialogue: 0,00:00:39.20,00:00:40.07,Default,,0,0,0,,la gente ofrece
Dialogue: 0,00:00:40.07,00:00:40.87,Default,,0,0,0,,lo que le sobra
Dialogue: 0,00:00:40.87,00:00:41.43,Default,,0,0,0,,antes de dejarlo
Dialogue: 0,00:00:41.43,00:00:42.07,Default,,0,0,0,,fuera.
Dialogue: 0,00:00:42.07,00:00:42.77,Default,,0,0,0,,Lo publicas,
Dialogue: 0,00:00:42.77,00:00:43.33,Default,,0,0,0,,queda ahí
Dialogue: 0,00:00:43.33,00:00:43.67,Default,,0,0,0,,para quien
Dialogue: 0,00:00:43.67,00:00:44.43,Default,,0,0,0,,lo busque.
Dialogue: 0,00:00:44.43,00:00:45.40,Default,,0,0,0,,Llega entero.
Dialogue: 0,00:00:45.40,00:00:46.43,Default,,0,0,0,,Llega a tiempo.
Dialogue: 0,00:00:46.43,00:00:46.80,Default,,0,0,0,,El carrito
Dialogue: 0,00:00:46.80,00:00:47.37,Default,,0,0,0,,y los libros
Dialogue: 0,00:00:47.37,00:00:47.83,Default,,0,0,0,,los subí
Dialogue: 0,00:00:47.83,00:00:48.40,Default,,0,0,0,,antes de que
Dialogue: 0,00:00:48.40,00:00:49.53,Default,,0,0,0,,se mojaran
Dialogue: 0,00:00:49.53,00:00:49.80,Default,,0,0,0,,del todo.
Dialogue: 0,00:00:49.80,00:00:50.57,Default,,0,0,0,,Ahora están ahí,
Dialogue: 0,00:00:50.57,00:00:50.77,Default,,0,0,0,,para quien
Dialogue: 0,00:00:50.77,00:00:51.37,Default,,0,0,0,,los quiera.
Dialogue: 0,00:00:51.37,00:00:52.67,Default,,0,0,0,,Imaginad si todos
Dialogue: 0,00:00:52.67,00:00:53.43,Default,,0,0,0,,compartiéramos
Dialogue: 0,00:00:53.43,00:00:53.93,Default,,0,0,0,,antes de dejar
Dialogue: 0,00:00:53.93,00:00:54.40,Default,,0,0,0,,las cosas
Dialogue: 0,00:00:54.40,00:00:55.23,Default,,0,0,0,,en la acera.
Dialogue: 0,00:00:55.23,00:00:56.47,Default,,0,0,0,,Nada acabaría así.
Dialogue: 0,00:00:56.47,00:00:57.17,Default,,0,0,0,,Esto lo hacemos
Dialogue: 0,00:00:57.17,00:00:57.77,Default,,0,0,0,,entre todos.
Dialogue: 0,00:00:57.77,00:00:58.77,Default,,0,0,0,,Givore.
