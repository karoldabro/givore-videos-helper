      "clips": [
        {
          "clip_id": "sub0",
          "text": "Dia uno...",
          "position": 0.0,
          "in": 0.0,
          "out": 1.28,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "buscando lo que\nla gente deja",
          "position": 1.28,
          "in": 0.0,
          "out": 1.8,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "en las calles\nde Espa\u00f1a.",
          "position": 3.08,
          "in": 0.0,
          "out": 1.5199999999999996,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "A ver que\nencontramos.",
          "position": 4.6,
          "in": 0.0,
          "out": 1.1600000000000001,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "De Madrid\na Barcelona.",
          "position": 5.76,
          "in": 0.0,
          "out": 1.4400000000000004,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "De Sevilla\na Valencia.",
          "position": 7.2,
          "in": 0.0,
          "out": 1.6399999999999997,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Muebles,\nelectrodomesticos,\njuguetes...",
          "position": 8.84,
          "in": 0.0,
          "out": 2.24,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "cosas que\nfuncionan,",
          "position": 11.08,
          "in": 0.0,
          "out": 1.4399999999999995,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "abandonadas en\nla acera.",
          "position": 12.52,
          "in": 0.0,
          "out": 1.200000000000001,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Cada dia se\npierden objetos\nutiles",
          "position": 13.72,
          "in": 0.0,
          "out": 2.16,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "por falta\nde conexion.",
          "position": 15.88,
          "in": 0.0,
          "out": 1.4000000000000004,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "Cosas con a\u00f1os\nde vida\npor delante.",
          "position": 17.28,
          "in": 0.0,
          "out": 1.3999999999999986,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "Que podrian\nseguir sirviendo.",
          "position": 18.68,
          "in": 0.0,
          "out": 1.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "Va, que os\nlo cuento.",
          "position": 20.52,
          "in": 0.0,
          "out": 0.879999999999999,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Givore.",
          "position": 21.4,
          "in": 0.0,
          "out": 0.40000000000000213,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "Subes lo que\nte sobra...",
          "position": 21.8,
          "in": 0.0,
          "out": 1.4399999999999977,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "y alguien de\ntu zona\nlo descubre.",
          "position": 23.24,
          "in": 0.0,
          "out": 1.6400000000000006,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "Rapido. Facil.",
          "position": 24.88,
          "in": 0.0,
          "out": 1.0800000000000018,
          "filters": []
        },
        {
          "clip_id": "sub18",
          "text": "Sin complicaciones.",
          "position": 25.96,
          "in": 0.0,
          "out": 1.1199999999999974,
          "filters": []
        },
        {
          "clip_id": "sub19",
          "text": "Os voy a\nser sincero.",
          "position": 27.08,
          "in": 0.0,
          "out": 1.360000000000003,
          "filters": []
        },
        {
          "clip_id": "sub20",
          "text": "Givore es nuevo.",
          "position": 28.44,
          "in": 0.0,
          "out": 1.1199999999999974,
          "filters": []
        },
        {
          "clip_id": "sub21",
          "text": "La comunidad\nse esta\nconstruyendo.",
          "position": 29.56,
          "in": 0.0,
          "out": 1.6799999999999997,
          "filters": []
        },
        {
          "clip_id": "sub22",
          "text": "Barrio a barrio.",
          "position": 31.24,
          "in": 0.0,
          "out": 0.879999999999999,
          "filters": []
        },
        {
          "clip_id": "sub23",
          "text": "Ciudad a ciudad.",
          "position": 32.12,
          "in": 0.0,
          "out": 0.8800000000000026,
          "filters": []
        },
        {
          "clip_id": "sub24",
          "text": "Con paciencia.",
          "position": 33.0,
          "in": 0.0,
          "out": 1.1199999999999974,
          "filters": []
        },
        {
          "clip_id": "sub25",
          "text": "No ocurre de\nun dia para otro.",
          "position": 34.12,
          "in": 0.0,
          "out": 1.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub26",
          "text": "Pero cada persona\nque se une,",
          "position": 36.08,
          "in": 0.0,
          "out": 1.3599999999999994,
          "filters": []
        },
        {
          "clip_id": "sub27",
          "text": "cada cosa que\nse comparte...",
          "position": 37.44,
          "in": 0.0,
          "out": 1.4000000000000057,
          "filters": []
        },
        {
          "clip_id": "sub28",
          "text": "eso si\ntiene sentido.",
          "position": 38.84,
          "in": 0.0,
          "out": 1.0,
          "filters": []
        },
        {
          "clip_id": "sub29",
          "text": "\u00bfTeneis algo en\ncasa que ya\nno usais?",
          "position": 39.84,
          "in": 0.0,
          "out": 2.3599999999999994,
          "filters": []
        },
        {
          "clip_id": "sub30",
          "text": "Subidlo antes\nde tirarlo.",
