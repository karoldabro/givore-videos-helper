      "clips": [
        {
          "clip_id": "sub0",
          "text": "Si vivis\nen Espa\u00f1a,",
          "position": 0.0,
          "in": 0.0,
          "out": 1.28,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "teneis que\nver esto.",
          "position": 1.28,
          "in": 0.0,
          "out": 1.2,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Lo que esta\npasando en\nlas calles",
          "position": 2.48,
          "in": 0.0,
          "out": 1.2400000000000002,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "de Madrid, Sevilla,\nValencia y Barcelona.",
          "position": 3.72,
          "in": 0.0,
          "out": 2.1199999999999997,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "Objetos en\nperfecto estado,",
          "position": 5.84,
          "in": 0.0,
          "out": 1.3600000000000003,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "tirados en\nla acera.",
          "position": 7.2,
          "in": 0.0,
          "out": 1.0799999999999992,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "Muebles, aparatos,\ncosas que valen.",
          "position": 8.28,
          "in": 0.0,
          "out": 2.16,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Y tu vecino\nde dos calles\nmas alla",
          "position": 10.44,
          "in": 0.0,
          "out": 1.5999999999999996,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "puede que necesite\njusto eso.",
          "position": 12.04,
          "in": 0.0,
          "out": 1.8000000000000007,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Y no lo sabe.",
          "position": 13.84,
          "in": 0.0,
          "out": 1.040000000000001,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "Hay gente a\nquinientos metros",
          "position": 14.88,
          "in": 0.0,
          "out": 1.1999999999999975,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "que le vendria\ngenial.",
          "position": 16.08,
          "in": 0.0,
          "out": 1.4400000000000013,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "Y no tienen\nni idea\nde que existe.",
          "position": 17.52,
          "in": 0.0,
          "out": 1.879999999999999,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "Yo ya voy\npreparado para\nestos momentos.",
          "position": 19.4,
          "in": 0.0,
          "out": 2.120000000000001,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Givore.",
          "position": 21.52,
          "in": 0.0,
          "out": 0.7199999999999989,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "Publicas lo que\nquieres dar...",
          "position": 22.24,
          "in": 0.0,
          "out": 1.4400000000000013,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "y alguien cercano\nlo descubre.",
          "position": 23.68,
          "in": 0.0,
          "out": 1.6000000000000014,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "Foto, titulo,\npublicado.",
