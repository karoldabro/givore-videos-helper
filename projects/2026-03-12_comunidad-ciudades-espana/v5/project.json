      "clips": [
        {
          "clip_id": "sub0",
          "text": "Cuatro ciudades.",
          "position": 0.0,
          "in": 0.0,
          "out": 1.28,
          "filters": []
        },
        {
          "clip_id": "sub1",
          "text": "Miles de\nobjetos utiles.",
          "position": 1.28,
          "in": 0.0,
          "out": 1.32,
          "filters": []
        },
        {
          "clip_id": "sub2",
          "text": "Una idea que\nlo puede\ncambiar todo.",
          "position": 2.6,
          "in": 0.0,
          "out": 1.4,
          "filters": []
        },
        {
          "clip_id": "sub3",
          "text": "Madrid, Sevilla,\nValencia, Barcelona.",
          "position": 4.0,
          "in": 0.0,
          "out": 2.12,
          "filters": []
        },
        {
          "clip_id": "sub4",
          "text": "En cada una\npasa lo mismo.",
          "position": 6.12,
          "in": 0.0,
          "out": 1.3200000000000003,
          "filters": []
        },
        {
          "clip_id": "sub5",
          "text": "Muebles, aparatos,\njuguetes...",
          "position": 7.44,
          "in": 0.0,
          "out": 2.04,
          "filters": []
        },
        {
          "clip_id": "sub6",
          "text": "abandonados en\nla acera.",
          "position": 9.48,
          "in": 0.0,
          "out": 1.5999999999999996,
          "filters": []
        },
        {
          "clip_id": "sub7",
          "text": "Alguien dejo\nesto aqui.",
          "position": 11.08,
          "in": 0.0,
          "out": 1.3200000000000003,
          "filters": []
        },
        {
          "clip_id": "sub8",
          "text": "Alguien mas alla\nlo necesita.",
          "position": 12.4,
          "in": 0.0,
          "out": 1.5600000000000005,
          "filters": []
        },
        {
          "clip_id": "sub9",
          "text": "Pero no se\nvan a encontrar\nnunca.",
          "position": 13.96,
          "in": 0.0,
          "out": 1.8399999999999999,
          "filters": []
        },
        {
          "clip_id": "sub10",
          "text": "La persona que\ntiene algo\nde sobra",
          "position": 15.8,
          "in": 0.0,
          "out": 1.5599999999999987,
          "filters": []
        },
        {
          "clip_id": "sub11",
          "text": "y la que\nlo busca...",
          "position": 17.36,
          "in": 0.0,
          "out": 1.3200000000000003,
          "filters": []
        },
        {
          "clip_id": "sub12",
          "text": "viven a\ndos calles.",
          "position": 18.68,
          "in": 0.0,
          "out": 1.2800000000000011,
          "filters": []
        },
        {
          "clip_id": "sub13",
          "text": "Y aqui es\ndonde entramos\ntodos.",
          "position": 19.96,
          "in": 0.0,
          "out": 2.0,
          "filters": []
        },
        {
          "clip_id": "sub14",
          "text": "Givore conecta\na quien comparte",
          "position": 21.96,
          "in": 0.0,
          "out": 1.6400000000000006,
          "filters": []
        },
        {
          "clip_id": "sub15",
          "text": "con quien busca.",
          "position": 23.6,
          "in": 0.0,
          "out": 0.9599999999999973,
          "filters": []
        },
        {
          "clip_id": "sub16",
          "text": "Publicas lo que\nte sobra...",
          "position": 24.56,
          "in": 0.0,
          "out": 1.360000000000003,
          "filters": []
        },
        {
          "clip_id": "sub17",
          "text": "y alguien cerca\nlo encuentra.",
          "position": 25.92,
          "in": 0.0,
          "out": 1.5999999999999979,
          "filters": []
        },
        {
          "clip_id": "sub18",
          "text": "Sin dinero.",
          "position": 27.52,
          "in": 0.0,
          "out": 0.9600000000000009,
          "filters": []
        },
        {
          "clip_id": "sub19",
          "text": "Sin intermediarios.",
          "position": 28.48,
          "in": 0.0,
          "out": 1.3999999999999986,
          "filters": []
        },
        {
          "clip_id": "sub20",
          "text": "Givore acaba\nde nacer.",
          "position": 29.88,
          "in": 0.0,
          "out": 1.240000000000002,
          "filters": []
        },
        {
          "clip_id": "sub21",
          "text": "Todavia estamos\nformando la\ncomunidad.",
          "position": 31.12,
          "in": 0.0,
          "out": 2.400000000000002,
          "filters": []
        },
        {
          "clip_id": "sub22",
          "text": "Ciudad a ciudad.",
          "position": 33.52,
          "in": 0.0,
          "out": 1.0799999999999983,
          "filters": []
        },
        {
          "clip_id": "sub23",
          "text": "Con calma\ny con ganas.",
          "position": 34.6,
          "in": 0.0,
          "out": 1.6000000000000014,
          "filters": []
        },
        {
          "clip_id": "sub24",
          "text": "No se monta\nde la noche\na la ma\u00f1ana.",
          "position": 36.2,
          "in": 0.0,
          "out": 1.759999999999998,
          "filters": []
        },
        {
          "clip_id": "sub25",
          "text": "Pero cada persona\nque se suma,",
          "position": 37.96,
          "in": 0.0,
          "out": 1.3999999999999986,
          "filters": []
        },
        {
          "clip_id": "sub26",
          "text": "cada objeto\nque encuentra\nun nuevo hogar...",
          "position": 39.36,
          "in": 0.0,
          "out": 2.280000000000001,
          "filters": []
        },
        {
          "clip_id": "sub27",
          "text": "eso es\nprogreso real.",
          "position": 41.64,
          "in": 0.0,
          "out": 1.2000000000000028,
          "filters": []
        },
        {
          "clip_id": "sub28",
          "text": "Antes de\ntirar algo,",
          "position": 42.84,
          "in": 0.0,
